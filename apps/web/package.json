{
  "name": "korea-real-estate-investment-firm-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.4.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "tsx scripts/clean-next-build.ts && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:e2e:up": "docker compose -f compose.e2e.yml up -d",
    "db:e2e:down": "docker compose -f compose.e2e.yml down -v",
    "test": "tsx --test tests/**/*.test.ts",
    "ops:cycle": "tsx scripts/run-ops-cycle.ts",
    "ops:worker": "tsx scripts/run-ops-worker.ts",
    "ops:worker:daemon": "tsx scripts/run-ops-worker-daemon.ts",
    "ops:preflight": "tsx scripts/run-ops-preflight.ts",
    "ingest:korea": "tsx scripts/run-korea-ingest.ts",
    "env:preflight": "tsx scripts/run-environment-preflight.ts",
    "e2e": "tsx scripts/run-e2e-smoke.ts",
    "e2e:list": "playwright test --list",
    "e2e:hosted": "playwright test e2e/operator-smoke.spec.ts",
    "e2e:hosted:mutations": "tsx scripts/run-hosted-mutation-guard.ts",
    "e2e:headed": "playwright test --headed",
    "e2e:local": "npm run db:e2e:up && npm run e2e"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.20.0",
    "clsx": "^2.1.1",
    "next": "15.0.0",
    "openai": "^4.61.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.53.0",
    "tailwind-merge": "^2.5.2",
    "viem": "^2.47.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
