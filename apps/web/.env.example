# =============================================================================
# Korea DC Underwriting / Investment Firm OS - Environment Variables
# -----------------------------------------------------------------------------
# Copy to `.env` for local dev. In Vercel, set each variable via the dashboard
# (Project Settings -> Environment Variables). Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Postgres, required)
# -----------------------------------------------------------------------------
# Prisma datasource. Use a pooled connection string in serverless (Neon/Supabase
# both expose a pooler endpoint). Must include `sslmode=require` for managed PG.
# Requires the `pgvector` extension (migrations run CREATE EXTENSION vector).
# Local: use the pgvector/pgvector:pg16 image (see compose.e2e.yml). Managed PG:
# enable the `vector` extension (Neon/Supabase/RDS all support it).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/korea_dc_underwriting

# -----------------------------------------------------------------------------
# Application base URL
# -----------------------------------------------------------------------------
# Public URL the app is served from. Used for blockchain metadata and any
# absolute link generation. In Vercel production, set this to your custom
# domain (e.g. https://app.example.com).
APP_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Admin auth - operator seats & browser sessions (required)
# -----------------------------------------------------------------------------
# Symmetric secret used to sign admin browser session cookies. Must be a long
# random string (>= 32 chars). Rotating invalidates all active sessions.
ADMIN_SESSION_SECRET=dev-secret-not-for-production
# Lifetime of a browser session in hours before forced re-auth.
ADMIN_SESSION_TTL_HOURS=12
# Escape hatch: when `true`, allows sessions not bound to a canonical User seat.
# Keep `false` everywhere except isolated local dev.
ADMIN_ALLOW_UNBOUND_BROWSER_SESSION=false

# Legacy basic-auth fallback (optional; prefer OIDC below).
# Format for the *_CREDENTIALS variants: `user1:pass1,user2:pass2`.
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=
ADMIN_BASIC_AUTH_VIEWER_CREDENTIALS=
ADMIN_BASIC_AUTH_ANALYST_CREDENTIALS=
ADMIN_BASIC_AUTH_ADMIN_CREDENTIALS=

# -----------------------------------------------------------------------------
# Admin auth - OIDC single sign-on (optional, recommended for production)
# -----------------------------------------------------------------------------
# Point at your IdP (Okta, Azure AD, Google Workspace, Keycloak, ...).
ADMIN_OIDC_ISSUER_URL=
ADMIN_OIDC_AUTHORIZATION_ENDPOINT=
ADMIN_OIDC_TOKEN_ENDPOINT=
ADMIN_OIDC_USERINFO_ENDPOINT=
ADMIN_OIDC_CLIENT_ID=
ADMIN_OIDC_CLIENT_SECRET=
# Must match an authorized redirect URI registered at the IdP.
ADMIN_OIDC_REDIRECT_URI=
ADMIN_OIDC_SCOPES=openid profile email
# Claim used as the canonical operator identifier (usually `email` or `sub`).
ADMIN_OIDC_IDENTIFIER_CLAIM=email
# Claim that carries the role (e.g. `role`, `groups`, `roles`).
ADMIN_OIDC_ROLE_CLAIM=role
# Fallback role when the claim is missing: VIEWER | ANALYST | ADMIN.
ADMIN_OIDC_DEFAULT_ROLE=VIEWER
# Comma-separated claim values that map to each in-app role.
ADMIN_OIDC_VIEWER_ROLES=
ADMIN_OIDC_ANALYST_ROLES=
ADMIN_OIDC_ADMIN_ROLES=

# -----------------------------------------------------------------------------
# Admin SCIM provisioning (optional)
# -----------------------------------------------------------------------------
# Bearer token the IdP presents when calling /api/admin/scim/*.
ADMIN_SCIM_TOKEN=
ADMIN_SCIM_PROVIDER=scim

# -----------------------------------------------------------------------------
# Document storage
# -----------------------------------------------------------------------------
# Local filesystem path used when no object-store is configured. On Vercel's
# serverless runtime only `/tmp` is writable, so configure S3-compatible
# storage below for any real deployment.
DOCUMENT_STORAGE_DIR=./storage/documents
# S3-compatible bucket. REQUIRED in production.
DOCUMENT_STORAGE_BUCKET=
DOCUMENT_STORAGE_REGION=
# Optional. Set for non-AWS S3 (Cloudflare R2, MinIO, Wasabi).
DOCUMENT_STORAGE_ENDPOINT=
DOCUMENT_STORAGE_ACCESS_KEY_ID=
DOCUMENT_STORAGE_SECRET_ACCESS_KEY=
# Optional key prefix inside the bucket (e.g. "prod/documents").
DOCUMENT_STORAGE_PREFIX=
# `true` for MinIO / R2 path-style addressing; usually `false` for AWS S3.
DOCUMENT_STORAGE_FORCE_PATH_STYLE=false

# -----------------------------------------------------------------------------
# OpenAI (optional - document extraction & research assists)
# -----------------------------------------------------------------------------
# When unset, the app falls back to heuristic extraction.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Ops queue, cron & alerting
# -----------------------------------------------------------------------------
# Bearer token required by /api/ops/* cron endpoints. Set this and configure
# a matching Vercel Cron (or external scheduler) to hit those routes.
OPS_CRON_TOKEN=
# Consecutive failures before an alert is emitted.
OPS_ALERT_FAILURE_STREAK=2
# Hours a pipeline can go without a successful run before it is marked stale.
OPS_ALERT_STALE_HOURS=6
# Primary / fallback / pager webhooks (Slack, Teams, PagerDuty, ...).
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_FALLBACK_WEBHOOK_URL=
OPS_ALERT_PAGER_WEBHOOK_URL=
OPS_ALERT_NOTIFY_ON_RECOVERY=false
# Optional label stored in ops run history & alert delivery logs.
OPS_ACTOR=
# Worker / queue knobs (safe defaults).
OPS_QUEUE_MAX_ATTEMPTS=3
OPS_QUEUE_BACKOFF_MS=60000
OPS_WORKER_POLL_MS=15000
OPS_WORKER_BATCH_SIZE=10

# -----------------------------------------------------------------------------
# Source cache & retry tuning
# -----------------------------------------------------------------------------
SOURCE_CACHE_TTL_HOURS=24
SOURCE_RETRY_COUNT=2
SOURCE_RETRY_BACKOFF_MS=250
SOURCE_REFRESH_STALE_HOURS=24
SOURCE_REFRESH_BATCH_SIZE=4
FX_SOURCE_CACHE_TTL_MINUTES=360

# -----------------------------------------------------------------------------
# Valuation engine
# -----------------------------------------------------------------------------
# `auto` (default), `python` (force python runner), or `node` (force TS runner).
VALUATION_ENGINE_MODE=auto
# Python interpreter used by the python valuation runner. Vercel does NOT ship
# Python on the Node runtime, so keep this set to `auto` or `node` in Vercel.
VAL_PYTHON_EXECUTABLE=python

# -----------------------------------------------------------------------------
# Korea public data APIs (optional, external integrations)
# -----------------------------------------------------------------------------
KOREA_GEOSPATIAL_API_URL=
KOREA_GEOSPATIAL_API_KEY=
KOREA_JUSO_API_KEY=
KOREA_JUSO_SEARCH_API_URL=https://business.juso.go.kr/addrlink/addrLinkApi.do
KOREA_JUSO_COORD_API_URL=https://business.juso.go.kr/addrlink/addrCoordApi.do
KOREA_BUILDING_API_URL=
KOREA_BUILDING_API_KEY=
KOREA_ENERGY_API_URL=
KOREA_ENERGY_API_KEY=
KOREA_MACRO_API_URL=
KOREA_MACRO_API_KEY=

# -----------------------------------------------------------------------------
# Public-data connector live adapters (lib/services/public-data/registry.ts)
# Each key flips its connector from the synthetic mock to a live API. Leaving a
# key unset keeps that connector on the mock (the analyzer still works). Setting
# more keys raises the share of LIVE/observed inputs in the provenance report.
# -----------------------------------------------------------------------------
# 국토교통부 건축물대장 (building-registry)
MOLIT_BUILDING_API_KEY=
# 국토교통부 상업업무용 실거래가 RTMS (transaction-comps)
RTMS_SERVICE_KEY=
# KEPCO 변전소/계통 (grid-access) — local file path or URL
KEPCO_SUBSTATION_DATA_PATH=
KEPCO_SUBSTATION_DATA_URL=
# 한국부동산원 R-ONE 상업용부동산 임대동향 (rent-comps) — 오피스 rent/vacancy.
# Defaults to the 임대동향 지역별(2024Q3~)_오피스 tables; override only to point
# at different STATBL_IDs (e.g. retail 중대형상가).
RONE_API_KEY=
RONE_API_BASE=
RONE_RENT_STATBL_ID=
RONE_VACANCY_STATBL_ID=
# V-World NSDI (use-zone 용도지역 + land-pricing 개별공시지가) — shared key.
# VWORLD_API_DOMAIN must match the key's registered service URL: V-World's NED
# data APIs reject keyed calls that omit the registered domain with INCORRECT_KEY.
VWORLD_API_KEY=
VWORLD_API_DOMAIN=
VWORLD_API_BASE=
VWORLD_USE_ZONE_BASE=
# 통계청 KOSIS (macro-micro 건설비/지역지표)
KOSIS_API_KEY=
KOSIS_API_BASE=

# KOSIS (Korean Statistical Information Service) - macro series
KOREA_KOSIS_API_KEY=
KOREA_KOSIS_BASE_URL=https://kosis.kr/openapi/statisticsData.do
KOREA_KOSIS_NEWEST_COUNT=1
# Inflation series
KOREA_KOSIS_INFLATION_USER_STATS_ID=
KOREA_KOSIS_INFLATION_PRD_SE=M
KOREA_KOSIS_INFLATION_ITEM_ID=
KOREA_KOSIS_INFLATION_ORG_ID=
KOREA_KOSIS_INFLATION_TBL_ID=
KOREA_KOSIS_INFLATION_ITM_ID=
KOREA_KOSIS_INFLATION_OBJ_L1=
KOREA_KOSIS_INFLATION_OBJ_L2=
# Construction cost series
KOREA_KOSIS_CONSTRUCTION_COST_USER_STATS_ID=
KOREA_KOSIS_CONSTRUCTION_COST_PRD_SE=Q
KOREA_KOSIS_CONSTRUCTION_COST_ITEM_ID=
KOREA_KOSIS_CONSTRUCTION_COST_ORG_ID=
KOREA_KOSIS_CONSTRUCTION_COST_TBL_ID=
KOREA_KOSIS_CONSTRUCTION_COST_ITM_ID=
KOREA_KOSIS_CONSTRUCTION_COST_OBJ_L1=
KOREA_KOSIS_CONSTRUCTION_COST_OBJ_L2=

# -----------------------------------------------------------------------------
# Global / US macro overlays (optional)
# -----------------------------------------------------------------------------
GLOBAL_MACRO_API_URL=
GLOBAL_MACRO_API_KEY=
GLOBAL_MARKET_API_URL=
GLOBAL_MARKET_API_KEY=
GLOBAL_FX_API_URL=
GLOBAL_FX_API_KEY=
US_MARKET_API_URL=
US_MARKET_API_KEY=
US_FRED_API_KEY=
US_FRED_BASE_URL=https://api.stlouisfed.org/fred/series/observations
US_FRED_OBSERVATION_LIMIT=12
US_BLS_BASE_URL=https://api.bls.gov/publicAPI/v2/timeseries/data/
US_BLS_API_KEY=
BLS_API_KEY=
US_TREASURY_API_BASE_URL=https://api.fiscaldata.treasury.gov/services/api/fiscal_service
US_TREASURY_POLICY_PROXY_ENDPOINT=
US_TREASURY_DEBT_COST_ENDPOINT=
US_TREASURY_DISCOUNT_RATE_ENDPOINT=
ECB_DATA_API_BASE_URL=https://data-api.ecb.europa.eu/service/data

# Worldwide cross-country macro (World Bank + OECD, keyless, opt-in).
# World Bank Indicators API needs no key, so live fetching is gated on an
# explicit enable flag (default off so CI/dev stay network-free, like
# ENABLE_OSM_GEOCODER). When enabled, lib/sources/adapters/world-bank.ts
# pulls GDP growth (NY.GDP.MKTP.KD.ZG), lending rate (FR.INR.LEND), CPI
# (FP.CPI.TOTL.ZG) and residential property price index (RPPI) for the
# WORLD_BANK_COUNTRIES basket and bridges them into the macro dashboard via
# fetchAllMacroData / getConfiguredProviders. The indicator->field mapping
# is scaffold-parity and must be validated against a live sample (RPPI
# coverage in particular is sparse/lagged). On any failure it degrades to an
# empty result and never throws.
ENABLE_WORLD_BANK_MACRO=false
WORLD_BANK_BASE_URL=https://api.worldbank.org/v2
WORLD_BANK_COUNTRIES=KR,US,JP,CN,IN,DE,GB,SG
WORLD_BANK_PER_PAGE=60
# OECD SDMX-JSON secondary probe (keyless). Off by default; the dataflow/key
# shape needs live calibration before per-series mapping is authoritative.
ENABLE_OECD_MACRO=false
OECD_SDMX_PROBE_URL=
# DBnomics — one keyless open API aggregating ~61 macro providers (World Bank,
# IMF, OECD, BIS, ECB, Eurostat, FRED…) under Provider>Dataset>Series. Needs no
# key, so live fetching is gated on an explicit flag (default off, like
# ENABLE_WORLD_BANK_MACRO). When enabled, lib/sources/adapters/dbnomics.ts pulls
# a small default basket (policy rate / CPI / GDP / property price across
# KR/US/JP/DE) and bridges it into the macro dashboard via fetchAllMacroData /
# getConfiguredProviders. Series codes are scaffold-parity and must be validated
# against a live sample. On any failure it degrades to empty and never throws.
ENABLE_DBNOMICS_MACRO=false
DBNOMICS_BASE_URL=https://api.db.nomics.world/v22

# -----------------------------------------------------------------------------
# Climate overlays (optional)
# -----------------------------------------------------------------------------
CLIMATE_OVERLAY_API_URL=
CLIMATE_OVERLAY_API_KEY=
NASA_POWER_API_URL=https://power.larc.nasa.gov/api/temporal/climatology/point
NASA_POWER_DAILY_API_URL=https://power.larc.nasa.gov/api/temporal/daily/point
NASA_POWER_REFERENCE_DATE=
NASA_POWER_RECENT_WINDOW_DAYS=30
NASA_GPM_OPENSEARCH_URL=https://gpm.nasa.gov/cgi-bin/api/GeoJSON/timeseries
NASA_GPM_DATASET=IMERG
NASA_FIRMS_MAP_KEY=
NASA_FIRMS_API_URL=https://firms.modaps.eosdis.nasa.gov/api/area/csv
NASA_FIRMS_SENSOR=VIIRS_SNPP_NRT
NASA_FIRMS_BBOX_DEGREES=0.25
NASA_FIRMS_LOOKBACK_DAYS=7

# -----------------------------------------------------------------------------
# Global power / grid / carbon-intensity connectors (optional)
# -----------------------------------------------------------------------------
# Data-center site quality is power-bound, so these add free global grid signals
# beyond Korea/KEPCO. Each connector (lib/sources/adapters/power-grid.ts) fails
# closed: leaving the key empty returns null/[] and never throws.
#
# ElectricityMaps — real-time grid carbon intensity (gCO2eq/kWh) + power
# breakdown by zone (e.g. KR, US-CAL-CISO, DE). Free tier; sent as an
# `auth-token` request header. Endpoint: https://api.electricitymap.org/v3
ELECTRICITYMAPS_API_TOKEN=
# EIA — US electricity retail price & generation mix. Free key, sent as the
# `api_key` query param. Endpoint: https://api.eia.gov/v2
EIA_API_KEY=
# ENTSO-E Transparency — European grid load/generation (XML; reachability
# scaffold only for now). Free security token. Endpoint:
# https://web-api.tp.entsoe.eu/api
ENTSOE_API_TOKEN=
# Ember — open global generation mix / carbon intensity / renewable share by
# country, yearly (215 areas) / monthly (88). Structural complement to the
# real-time ElectricityMaps signal. Free `api_key` query param; data licensed
# CC BY 4.0 ("Ember — Yearly Electricity Data"). Endpoint:
# https://api.ember-energy.org/v1 (override with EMBER_API_BASE)
EMBER_API_KEY=
EMBER_API_BASE=

# -----------------------------------------------------------------------------
# Maps (optional)
# -----------------------------------------------------------------------------
# Public Kakao Maps JavaScript API key. When set, the property explorer renders
# an interactive Kakao map (best coverage for Korean addresses). Leave empty to
# fall back to Leaflet + OpenStreetMap, which requires no key. Register the
# deployment domain on the Kakao Developers console for the key to work.
KAKAO_MAP_API_KEY=
# Kakao Local REST key (SERVER-SIDE SECRET, distinct from the public map key).
# When set, /property-analyze geocodes arbitrary Korean addresses live
# (coordinates + reconstructed 19-digit PNU); otherwise the deterministic demo
# geocoder is used. Do not expose to the browser.
KAKAO_REST_API_KEY=
# Keyless live geocoding via OSM Nominatim (no API key needed). Set to true to
# resolve arbitrary Korean addresses to real coordinates when no Kakao key is
# configured. Off by default (CI/dev use the deterministic demo geocoder).
ENABLE_OSM_GEOCODER=false
# Keyless OSM Overpass POI-density connector (amenity / foot-traffic proxy for
# site demand). When true, lib/services/dc-intel/overpass-poi.ts counts nearby
# POIs (food/retail/transit/office/health/education/finance) within a radius and
# computes a 0–100 amenity/walkability score. Off by default; respect the public
# Overpass fair-use limits (~10k req/day). Data is © OpenStreetMap contributors.
ENABLE_OVERPASS_POI=false
# Optional Overpass endpoint override (e.g. a self-hosted mirror). Defaults to
# https://overpass-api.de/api/interpreter when unset.
OVERPASS_API_URL=
# Keyless worldwide natural-hazard site risk via GFDRR ThinkHazard!
# (https://thinkhazard.org). When enabled, lib/services/dc-intel/thinkhazard.ts
# resolves a lat/lng (or admin division id) to classified hazard levels for 11
# natural hazards and a 0–100 site-risk score. Off by default; on any failure it
# returns an empty result (never throws). Override the base URL only if proxying.
ENABLE_THINKHAZARD=false
THINKHAZARD_API_BASE=https://thinkhazard.org

# -----------------------------------------------------------------------------
# Blockchain / tokenization (optional)
# -----------------------------------------------------------------------------
# Base URL used when minting token metadata; falls back to APP_BASE_URL.
BLOCKCHAIN_METADATA_BASE_URL=http://localhost:3000
BLOCKCHAIN_CHAIN_ID=
BLOCKCHAIN_CHAIN_NAME=
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_REGISTRY_ADDRESS=
# NEVER store a real private key in a committed env file. Use Vercel secrets.
BLOCKCHAIN_PRIVATE_KEY=
# `true` runs the tokenization stack in offline/mock mode (no RPC calls).
BLOCKCHAIN_MOCK_MODE=true

# -----------------------------------------------------------------------------
# Playwright / E2E guards (do not enable in production)
# -----------------------------------------------------------------------------
# When `true`, allows destructive mutations against hosted environments whose
# hostname matches PLAYWRIGHT_ALLOWED_HOST_PATTERN. Keep `false` in prod.
PLAYWRIGHT_ALLOW_HOSTED_MUTATIONS=false
PLAYWRIGHT_ALLOWED_HOST_PATTERN=staging
# When `true`, opts the production `next start` build used by the browser E2E
# out of production-only hard-blocks (mock blockchain, local document storage)
# so the suite can run with no S3 / RPC. The production preflight rejects it;
# never enable it in real production.
E2E_PRODUCTION_BUILD=false

# -----------------------------------------------------------------------------
# Edge protection (IP allowlist + rate limiting)
# -----------------------------------------------------------------------------
# Comma-separated CIDR / IP entries that are admitted to /admin/* and
# /api/admin/*. Empty = no allowlist (every IP allowed). Combine with
# Vercel Firewall rules for defense-in-depth.
ADMIN_IP_ALLOWLIST=
# Same for /api/ops/* (typically the cron egress IPs).
OPS_IP_ALLOWLIST=
# Per-IP rate limit windows (defaults are conservative single-tenant values).
ADMIN_API_RATE_WINDOW_MS=60000
ADMIN_API_RATE_MAX=240
OPS_API_RATE_WINDOW_MS=60000
OPS_API_RATE_MAX=60
PUBLIC_API_RATE_WINDOW_MS=60000
PUBLIC_API_RATE_MAX=60

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# debug | info | warn | error. Defaults: debug in dev, info in production.
LOG_LEVEL=
# Webhook receiving JSON error envelopes (Datadog, Logtail, custom pipelines).
# For Sentry, prefer SENTRY_DSN below — both can be set at the same time.
ERROR_REPORT_WEBHOOK_URL=

# Sentry — DSN auto-activates @sentry/nextjs at runtime (server + edge).
# Leave SENTRY_DSN unset in local dev to keep network silent.
SENTRY_DSN=
# Override env tag; defaults to VERCEL_ENV → NODE_ENV.
SENTRY_ENVIRONMENT=
# Sample rates (0–1). Traces default 0.1, profiles default 0.
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_PROFILES_SAMPLE_RATE=
# Source-map upload during `next build` (CI only — never in client bundle).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# -----------------------------------------------------------------------------
# Audit retention (`npm run audit:prune`)
# -----------------------------------------------------------------------------
AUDIT_RETENTION_DAYS=365
OPS_ALERT_DELIVERY_RETENTION_DAYS=180
NOTIFICATION_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# External data-source connectors (quarterly-report / tenant-credit)
# -----------------------------------------------------------------------------
# OpenDART (전자공시) free API key — https://opendart.fss.or.kr → 인증키 신청.
# Powers the tenant/sponsor corporate-financials connector
# (lib/services/quarterly-report/connectors/dart-financials.ts) that feeds the
# credit path. Unset = connector returns null and callers fall back to the
# document-extraction / heuristic credit path. Also used by the disclosure-list
# connector (connectors/dart.ts).
DART_API_KEY=

# OpenAQ (https://openaq.org) free v3 API key — request at https://docs.openaq.org
# (sent as the X-API-Key header). Powers the air-quality / ESG site-quality
# connector (lib/services/dc-intel/openaq.ts) that returns representative
# latest PM2.5/PM10/NO2/O3 near an asset. Unset = connector makes no network
# call and returns an empty result.
OPENAQ_API_KEY=
