# =============================================================================
# Korea DC Underwriting / Investment Firm OS - Environment Variables
# -----------------------------------------------------------------------------
# Copy to `.env` for local dev. In Vercel, set each variable via the dashboard
# (Project Settings -> Environment Variables). Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Postgres, required)
# -----------------------------------------------------------------------------
# Prisma datasource. Use a pooled connection string in serverless (Neon/Supabase
# both expose a pooler endpoint). Must include `sslmode=require` for managed PG.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/korea_dc_underwriting

# -----------------------------------------------------------------------------
# Application base URL
# -----------------------------------------------------------------------------
# Public URL the app is served from. Used for blockchain metadata and any
# absolute link generation. In Vercel production, set this to your custom
# domain (e.g. https://app.example.com).
APP_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Admin auth - operator seats & browser sessions (required)
# -----------------------------------------------------------------------------
# Symmetric secret used to sign admin browser session cookies. Must be a long
# random string (>= 32 chars). Rotating invalidates all active sessions.
ADMIN_SESSION_SECRET=dev-secret-not-for-production
# Lifetime of a browser session in hours before forced re-auth.
ADMIN_SESSION_TTL_HOURS=12
# Escape hatch: when `true`, allows sessions not bound to a canonical User seat.
# Keep `false` everywhere except isolated local dev.
ADMIN_ALLOW_UNBOUND_BROWSER_SESSION=false

# Legacy basic-auth fallback (optional; prefer OIDC below).
# Format for the *_CREDENTIALS variants: `user1:pass1,user2:pass2`.
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=
ADMIN_BASIC_AUTH_VIEWER_CREDENTIALS=
ADMIN_BASIC_AUTH_ANALYST_CREDENTIALS=
ADMIN_BASIC_AUTH_ADMIN_CREDENTIALS=

# -----------------------------------------------------------------------------
# Admin auth - OIDC single sign-on (optional, recommended for production)
# -----------------------------------------------------------------------------
# Point at your IdP (Okta, Azure AD, Google Workspace, Keycloak, ...).
ADMIN_OIDC_ISSUER_URL=
ADMIN_OIDC_AUTHORIZATION_ENDPOINT=
ADMIN_OIDC_TOKEN_ENDPOINT=
ADMIN_OIDC_USERINFO_ENDPOINT=
ADMIN_OIDC_CLIENT_ID=
ADMIN_OIDC_CLIENT_SECRET=
# Must match an authorized redirect URI registered at the IdP.
ADMIN_OIDC_REDIRECT_URI=
ADMIN_OIDC_SCOPES=openid profile email
# Claim used as the canonical operator identifier (usually `email` or `sub`).
ADMIN_OIDC_IDENTIFIER_CLAIM=email
# Claim that carries the role (e.g. `role`, `groups`, `roles`).
ADMIN_OIDC_ROLE_CLAIM=role
# Fallback role when the claim is missing: VIEWER | ANALYST | ADMIN.
ADMIN_OIDC_DEFAULT_ROLE=VIEWER
# Comma-separated claim values that map to each in-app role.
ADMIN_OIDC_VIEWER_ROLES=
ADMIN_OIDC_ANALYST_ROLES=
ADMIN_OIDC_ADMIN_ROLES=

# -----------------------------------------------------------------------------
# Admin SCIM provisioning (optional)
# -----------------------------------------------------------------------------
# Bearer token the IdP presents when calling /api/admin/scim/*.
ADMIN_SCIM_TOKEN=
ADMIN_SCIM_PROVIDER=scim

# -----------------------------------------------------------------------------
# Document storage
# -----------------------------------------------------------------------------
# Local filesystem path used when no object-store is configured. On Vercel's
# serverless runtime only `/tmp` is writable, so configure S3-compatible
# storage below for any real deployment.
DOCUMENT_STORAGE_DIR=./storage/documents
DOCUMENT_STORAGE_BUCKET=
DOCUMENT_STORAGE_ENDPOINT=
DOCUMENT_STORAGE_ACCESS_KEY_ID=
DOCUMENT_STORAGE_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# OpenAI (optional - document extraction & research assists)
# -----------------------------------------------------------------------------
# When unset, the app falls back to heuristic extraction.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Ops queue, cron & alerting
# -----------------------------------------------------------------------------
# Bearer token required by /api/ops/* cron endpoints. Set this and configure
# a matching Vercel Cron (or external scheduler) to hit those routes.
OPS_CRON_TOKEN=
# Consecutive failures before an alert is emitted.
OPS_ALERT_FAILURE_STREAK=2
# Hours a pipeline can go without a successful run before it is marked stale.
OPS_ALERT_STALE_HOURS=6
# Primary / fallback / pager webhooks (Slack, Teams, PagerDuty, ...).
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_FALLBACK_WEBHOOK_URL=
OPS_ALERT_PAGER_WEBHOOK_URL=
OPS_ALERT_NOTIFY_ON_RECOVERY=false
# Optional label stored in ops run history & alert delivery logs.
OPS_ACTOR=
# Worker / queue knobs (safe defaults).
OPS_QUEUE_MAX_ATTEMPTS=3
OPS_QUEUE_BACKOFF_MS=60000
OPS_WORKER_POLL_MS=15000
OPS_WORKER_BATCH_SIZE=10

# -----------------------------------------------------------------------------
# Source cache & retry tuning
# -----------------------------------------------------------------------------
SOURCE_CACHE_TTL_HOURS=24
SOURCE_RETRY_COUNT=2
SOURCE_RETRY_BACKOFF_MS=250
SOURCE_REFRESH_STALE_HOURS=24
SOURCE_REFRESH_BATCH_SIZE=4
FX_SOURCE_CACHE_TTL_MINUTES=360

# -----------------------------------------------------------------------------
# Valuation engine
# -----------------------------------------------------------------------------
# `auto` (default), `python` (force python runner), or `node` (force TS runner).
VALUATION_ENGINE_MODE=auto
# Python interpreter used by the python valuation runner. Vercel does NOT ship
# Python on the Node runtime, so keep this set to `auto` or `node` in Vercel.
VAL_PYTHON_EXECUTABLE=python

# -----------------------------------------------------------------------------
# Korea public data APIs (optional, external integrations)
# -----------------------------------------------------------------------------
KOREA_GEOSPATIAL_API_URL=
KOREA_GEOSPATIAL_API_KEY=
KOREA_JUSO_API_KEY=
KOREA_JUSO_SEARCH_API_URL=https://business.juso.go.kr/addrlink/addrLinkApi.do
KOREA_JUSO_COORD_API_URL=https://business.juso.go.kr/addrlink/addrCoordApi.do
KOREA_BUILDING_API_URL=
KOREA_BUILDING_API_KEY=
KOREA_ENERGY_API_URL=
KOREA_ENERGY_API_KEY=
KOREA_MACRO_API_URL=
KOREA_MACRO_API_KEY=

# KOSIS (Korean Statistical Information Service) - macro series
KOREA_KOSIS_API_KEY=
KOREA_KOSIS_BASE_URL=https://kosis.kr/openapi/statisticsData.do
KOREA_KOSIS_NEWEST_COUNT=1
# Inflation series
KOREA_KOSIS_INFLATION_USER_STATS_ID=
KOREA_KOSIS_INFLATION_PRD_SE=M
KOREA_KOSIS_INFLATION_ITEM_ID=
KOREA_KOSIS_INFLATION_ORG_ID=
KOREA_KOSIS_INFLATION_TBL_ID=
KOREA_KOSIS_INFLATION_ITM_ID=
KOREA_KOSIS_INFLATION_OBJ_L1=
KOREA_KOSIS_INFLATION_OBJ_L2=
# Construction cost series
KOREA_KOSIS_CONSTRUCTION_COST_USER_STATS_ID=
KOREA_KOSIS_CONSTRUCTION_COST_PRD_SE=Q
KOREA_KOSIS_CONSTRUCTION_COST_ITEM_ID=
KOREA_KOSIS_CONSTRUCTION_COST_ORG_ID=
KOREA_KOSIS_CONSTRUCTION_COST_TBL_ID=
KOREA_KOSIS_CONSTRUCTION_COST_ITM_ID=
KOREA_KOSIS_CONSTRUCTION_COST_OBJ_L1=
KOREA_KOSIS_CONSTRUCTION_COST_OBJ_L2=

# -----------------------------------------------------------------------------
# Global / US macro overlays (optional)
# -----------------------------------------------------------------------------
GLOBAL_MACRO_API_URL=
GLOBAL_MACRO_API_KEY=
GLOBAL_MARKET_API_URL=
GLOBAL_MARKET_API_KEY=
GLOBAL_FX_API_URL=
GLOBAL_FX_API_KEY=
US_MARKET_API_URL=
US_MARKET_API_KEY=
US_FRED_API_KEY=
US_FRED_BASE_URL=https://api.stlouisfed.org/fred/series/observations
US_FRED_OBSERVATION_LIMIT=12
US_BLS_BASE_URL=https://api.bls.gov/publicAPI/v2/timeseries/data/
US_BLS_API_KEY=
BLS_API_KEY=
US_TREASURY_API_BASE_URL=https://api.fiscaldata.treasury.gov/services/api/fiscal_service
US_TREASURY_POLICY_PROXY_ENDPOINT=
US_TREASURY_DEBT_COST_ENDPOINT=
US_TREASURY_DISCOUNT_RATE_ENDPOINT=
ECB_DATA_API_BASE_URL=https://data-api.ecb.europa.eu/service/data

# -----------------------------------------------------------------------------
# Climate overlays (optional)
# -----------------------------------------------------------------------------
CLIMATE_OVERLAY_API_URL=
CLIMATE_OVERLAY_API_KEY=
NASA_POWER_API_URL=https://power.larc.nasa.gov/api/temporal/climatology/point
NASA_POWER_DAILY_API_URL=https://power.larc.nasa.gov/api/temporal/daily/point
NASA_POWER_REFERENCE_DATE=
NASA_POWER_RECENT_WINDOW_DAYS=30
NASA_GPM_OPENSEARCH_URL=https://gpm.nasa.gov/cgi-bin/api/GeoJSON/timeseries
NASA_GPM_DATASET=IMERG
NASA_FIRMS_MAP_KEY=
NASA_FIRMS_API_URL=https://firms.modaps.eosdis.nasa.gov/api/area/csv
NASA_FIRMS_SENSOR=VIIRS_SNPP_NRT
NASA_FIRMS_BBOX_DEGREES=0.25
NASA_FIRMS_LOOKBACK_DAYS=7

# -----------------------------------------------------------------------------
# Blockchain / tokenization (optional)
# -----------------------------------------------------------------------------
# Base URL used when minting token metadata; falls back to APP_BASE_URL.
BLOCKCHAIN_METADATA_BASE_URL=http://localhost:3000
BLOCKCHAIN_CHAIN_ID=
BLOCKCHAIN_CHAIN_NAME=
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_REGISTRY_ADDRESS=
# NEVER store a real private key in a committed env file. Use Vercel secrets.
BLOCKCHAIN_PRIVATE_KEY=
# `true` runs the tokenization stack in offline/mock mode (no RPC calls).
BLOCKCHAIN_MOCK_MODE=true

# -----------------------------------------------------------------------------
# Playwright / E2E guards (do not enable in production)
# -----------------------------------------------------------------------------
# When `true`, allows destructive mutations against hosted environments whose
# hostname matches PLAYWRIGHT_ALLOWED_HOST_PATTERN. Keep `false` in prod.
PLAYWRIGHT_ALLOW_HOSTED_MUTATIONS=false
PLAYWRIGHT_ALLOWED_HOST_PATTERN=staging
