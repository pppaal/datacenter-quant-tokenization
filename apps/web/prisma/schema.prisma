  updatedAt        DateTime       @updatedAt
  portfolioAsset   PortfolioAsset @relation(fields: [portfolioAssetId], references: [id], onDelete: Cascade)
  debtFacility     DebtFacility?  @relation(fields: [debtFacilityId], references: [id], onDelete: SetNull)

  @@index([portfolioAssetId, asOfDate, status])
  @@index([debtFacilityId, asOfDate])
}

model ExitCase {
  id                String         @id @default(cuid())
  portfolioAssetId  String
  caseLabel         String
  statusLabel       String         @default("ACTIVE")
  underwritingValueKrw Float?
  targetExitDate    DateTime?
  targetCapRatePct  Float?
  targetIrrPct      Float?
  probabilityPct    Float?
  buyerUniverse     String?
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  portfolioAsset    PortfolioAsset @relation(fields: [portfolioAssetId], references: [id], onDelete: Cascade)

  @@index([portfolioAssetId, statusLabel, targetExitDate])
}

model Fund {
  id                  String          @id @default(cuid())
  code                String          @unique
  name                String
  strategy            String?
  baseCurrency        String          @default("KRW")
  targetSizeKrw       Float?
  committedCapitalKrw Float?
  investedCapitalKrw  Float?
  dryPowderKrw        Float?
  vintageYear         Int?
  thesis              String?
  portfolioId         String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  portfolio           Portfolio?      @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  vehicles            Vehicle[]
  mandates            Mandate[]
  commitments         Commitment[]
  capitalCalls        CapitalCall[]
  distributions       Distribution[]
  investorReports     InvestorReport[]
  ddqResponses        DdqResponse[]

  @@index([strategy, vintageYear])
}

model Vehicle {
  id              String        @id @default(cuid())
  fundId          String?
  name            String
  vehicleType     VehicleType   @default(FUND)
  jurisdiction    String?
  assetClassFocus String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  fund            Fund?         @relation(fields: [fundId], references: [id], onDelete: SetNull)
  mandates        Mandate[]
  commitments     Commitment[]
  capitalCalls    CapitalCall[]
  distributions   Distribution[]

  @@index([fundId, vehicleType])
}

model Mandate {
  id             String   @id @default(cuid())
  fundId         String?
  vehicleId      String?
  title          String
  investorName   String?
  strategy       String?
  targetAumKrw   Float?
  statusLabel    String   @default("ACTIVE")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  fund           Fund?    @relation(fields: [fundId], references: [id], onDelete: SetNull)
  vehicle        Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([fundId, statusLabel])
  @@index([vehicleId, statusLabel])
}

model Investor {
  id            String          @id @default(cuid())
  code          String          @unique
  name          String
  investorType  String?
  domicile      String?
  contactName   String?
  contactEmail  String?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  commitments   Commitment[]
  investorReports InvestorReport[]
  ddqResponses  DdqResponse[]

  @@index([investorType, domicile])
}

model Commitment {
  id             String    @id @default(cuid())
  fundId         String
  vehicleId      String?
  investorId     String
  commitmentKrw  Float
  calledKrw      Float     @default(0)
  distributedKrw Float     @default(0)
  recallableKrw  Float?
  signedAt       DateTime?
  statusLabel    String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  fund           Fund      @relation(fields: [fundId], references: [id], onDelete: Cascade)
  vehicle        Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  investor       Investor  @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([fundId, investorId, vehicleId])
  @@index([fundId, statusLabel])
  @@index([investorId, statusLabel])
}

model CapitalCall {
  id          String            @id @default(cuid())
  fundId      String
  vehicleId   String?
  callDate    DateTime
  dueDate     DateTime?
  amountKrw   Float
  purpose     String?
  status      CapitalCallStatus @default(PLANNED)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  fund        Fund              @relation(fields: [fundId], references: [id], onDelete: Cascade)
  vehicle     Vehicle?          @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([fundId, callDate, status])
}

model Distribution {
  id          String             @id @default(cuid())
  fundId      String
  vehicleId   String?
  distributionDate DateTime
  amountKrw   Float
  purpose     String?
  status      DistributionStatus @default(PLANNED)
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  fund        Fund               @relation(fields: [fundId], references: [id], onDelete: Cascade)
  vehicle     Vehicle?           @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([fundId, distributionDate, status])
}

model InvestorReport {
  id           String             @id @default(cuid())
  fundId        String
  investorId    String?
  reportType   InvestorReportType @default(QUARTERLY_UPDATE)
  releaseStatus InvestorReportReleaseStatus @default(DRAFT)
  title        String
  periodEnd    DateTime?
  draftSummary String?
  reviewNotes  String?
  reviewedAt   DateTime?
  reviewedById String?
  publishedAt  DateTime?
  releasedById String?
  storagePath  String?
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  fund         Fund               @relation(fields: [fundId], references: [id], onDelete: Cascade)
  investor     Investor?          @relation(fields: [investorId], references: [id], onDelete: SetNull)
  reviewedBy   User?              @relation("InvestorReportReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  releasedBy   User?              @relation("InvestorReportReleasedBy", fields: [releasedById], references: [id], onDelete: SetNull)

  @@index([fundId, reportType, periodEnd])
  @@index([investorId, reportType, periodEnd])
  @@index([fundId, releaseStatus, periodEnd])
}

model DdqResponse {
  id          String    @id @default(cuid())
  fundId      String?
  investorId  String?
  title       String
  question    String
  answer      String?
  statusLabel String    @default("DRAFT")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  fund        Fund?     @relation(fields: [fundId], references: [id], onDelete: SetNull)
  investor    Investor? @relation(fields: [investorId], references: [id], onDelete: SetNull)

  @@index([fundId, statusLabel])
  @@index([investorId, statusLabel])
}

enum NotificationType {
  IC_PACKET_LOCKED
  IC_PACKET_DECIDED
  IC_PACKET_RELEASED
  RESEARCH_APPROVED
  DILIGENCE_BLOCKED
  SYSTEM
}

enum NotificationSeverity {
  INFO
  WARN
  CRITICAL
}

model Notification {
  id           String               @id @default(cuid())
  type         NotificationType
  severity     NotificationSeverity @default(INFO)
  title        String
  body         String?
  entityType   String?
  entityId     String?
  audienceRole String?
  readAt       DateTime?
  createdAt    DateTime             @default(now())

  @@index([createdAt])
  @@index([readAt])
}

enum QuarterlyNarrativeStatus {
  DRAFT
  HUMAN_REVIEWED
  PUBLISHED
  SUPERSEDED
}

model QuarterlyMarketSnapshot {
  id                            String      @id @default(cuid())
  market                        String
  submarket                     String
  assetClass                    AssetClass?
  quarter                       String
  quarterEndDate                DateTime
  transactionCount              Int?
  transactionVolumeKrw          BigInt?
  medianPriceKrwPerSqm          Decimal?    @db.Decimal(18, 2)
  priceChangeQoQPct             Decimal?    @db.Decimal(10, 4)
  priceChangeYoYPct             Decimal?    @db.Decimal(10, 4)
  vacancyPct                    Decimal?    @db.Decimal(6, 3)
  rentKrwPerSqm                 Decimal?    @db.Decimal(12, 2)
  capRatePct                    Decimal?    @db.Decimal(6, 3)
  newConstructionApprovalsCount Int?
  newConstructionApprovalsGfaSqm Decimal?   @db.Decimal(18, 2)
  baseRatePct                   Decimal?    @db.Decimal(6, 3)
  krwUsd                        Decimal?    @db.Decimal(12, 4)
  cpiYoYPct                     Decimal?    @db.Decimal(6, 3)
  gdpYoYPct                     Decimal?    @db.Decimal(6, 3)
  rawMetrics                    Json
  sourceManifest                Json
  generatedAt                   DateTime    @default(now())
  updatedAt                     DateTime    @updatedAt
  narratives                    QuarterlyMarketNarrative[] @relation("SnapshotNarratives")

  @@unique([market, submarket, assetClass, quarter], name: "market_submarket_assetClass_quarter")
  @@index([quarter])
  @@index([market, submarket])
}

model QuarterlyMarketNarrative {
  id                String                   @id @default(cuid())
  snapshotId        String
  snapshot          QuarterlyMarketSnapshot  @relation("SnapshotNarratives", fields: [snapshotId], references: [id], onDelete: Cascade)
  priorQuarterId    String?
  status            QuarterlyNarrativeStatus @default(DRAFT)
  model             String
  promptTokens      Int?
  completionTokens  Int?
  headline          String
  marketPulse       String
  supplyPipeline    String
  capitalMarkets    String
  outlook           String
  overweightList    Json
  underweightList   Json
  risks             Json
  reviewedBy        String?
  reviewedAt        DateTime?
  publishedAt       DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([snapshotId])
  @@index([status])
}
