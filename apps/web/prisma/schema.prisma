generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ANALYST
  VIEWER
}

enum AssetStage {
  SCREENING
  LAND_SECURED
  POWER_REVIEW
  PERMITTING
  CONSTRUCTION
  LIVE
  STABILIZED
}

enum AssetStatus {
  INTAKE
  ENRICHING
  UNDER_REVIEW
  IC_READY
  APPROVED
  DECLINED
  ON_HOLD
}

enum AssetClass {
  OFFICE
  INDUSTRIAL
  RETAIL
  MULTIFAMILY
  HOTEL
  DATA_CENTER
  LAND
  MIXED_USE
}

enum DocumentType {
  IM
  POWER_STUDY
  PERMIT
  LEASE
  MODEL
  SITE_PHOTO
  GRID_NOTICE
  REPORT
  OTHER
}

enum SourceStatus {
  FRESH
  STALE
  FAILED
  MANUAL
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ValuationStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum ReadinessStatus {
  NOT_STARTED
  READY
  ANCHORED
  ERROR

  @@map("RegistryStatus")
}

enum CapexCategory {
  LAND
  SHELL_CORE
  ELECTRICAL
  MECHANICAL
  IT_FIT_OUT
  SOFT_COST
  CONTINGENCY
}

enum LeaseStatus {
  PIPELINE
  SIGNED
  ACTIVE
  EXPIRED
}

enum DebtFacilityType {
  CONSTRUCTION
  TERM
  REVOLVER
}

enum AmortizationProfile {
  INTEREST_ONLY
  MORTGAGE
  SCULPTED
  BULLET
}

enum DealStage {
  SOURCED
  SCREENED
  NDA
  LOI
  DD
  IC
  CLOSING
  ASSET_MANAGEMENT
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActivityType {
  GENERAL
  NOTE
  STAGE_CHANGED
  NEXT_ACTION
  TASK_CREATED
  TASK_UPDATED
  RISK_CREATED
  RISK_UPDATED
  COUNTERPARTY_ADDED
}

enum DealRequestStatus {
  REQUESTED
  RECEIVED
  WAIVED
}

enum DealBidStatus {
  DRAFT
  SUBMITTED
  COUNTERED
  BAFO
  ACCEPTED
  DECLINED
  WITHDRAWN
}

enum DealLenderQuoteStatus {
  INDICATED
  TERM_SHEET
  CREDIT_APPROVED
  DECLINED
  WITHDRAWN
  CLOSED
}

enum DealNegotiationEventType {
  SELLER_COUNTER
  BUYER_FEEDBACK
  EXCLUSIVITY_GRANTED
  EXCLUSIVITY_EXTENDED
  PROCESS_UPDATE
}

enum DealOriginationSource {
  BROKERED
  DIRECT_OWNER
  LENDER_CHANNEL
  ADVISOR
  PROPRIETARY
  INBOUND
}

enum DealLossReason {
  PRICE
  EXECUTION
  COMPETITION
  TIMING
  FINANCING
  IC_DECLINE
  STRATEGY
  OTHER
}

enum RelationshipCoverageStatus {
  PRIMARY
  BACKUP
  PASSIVE
}

enum DealDiligenceWorkstreamType {
  LEGAL
  TECHNICAL
  ENVIRONMENTAL
  COMMERCIAL
  TAX
  INSURANCE
  LEASING
  FINANCING
}

enum DealDiligenceWorkstreamStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  READY_FOR_SIGNOFF
  SIGNED_OFF
}

enum PortfolioAssetStatus {
  ACTIVE
  WATCHLIST
  EXITING
  EXITED
}

enum CovenantStatus {
  PASS
  WATCH
  BREACH
}

enum ResearchSyncTriggerType {
  WORKSPACE_REFRESH
  SCHEDULED
  MANUAL
}

enum ResearchViewType {
  SOURCE
  HOUSE
}

enum ResearchApprovalStatus {
  DRAFT
  APPROVED
  SUPERSEDED
}

enum SourceRefreshTriggerType {
  MANUAL
  SCHEDULED
}

enum AdminAccessScopeType {
  ASSET
  DEAL
  PORTFOLIO
  FUND
}

enum OpsWorkType {
  OPS_CYCLE
  SOURCE_REFRESH
  RESEARCH_SYNC
}

enum OpsWorkStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  DEAD_LETTER
}

enum CapitalCallStatus {
  PLANNED
  ISSUED
  FUNDED
  CANCELLED
}

enum DistributionStatus {
  PLANNED
  ISSUED
  PAID
  CANCELLED
}

enum VehicleType {
  FUND
  SMA
  JV
  SPV
}

enum InvestorReportType {
  QUARTERLY_UPDATE
  CAPITAL_ACCOUNT
  DDQ_RESPONSE
  OTHER
}

enum InvestorReportReleaseStatus {
  DRAFT
  INTERNAL_REVIEW
  READY
  RELEASED
}

enum CommitteeMeetingStatus {
  DRAFT
  SCHEDULED
  HELD
  CLOSED
}

enum CommitteePacketStatus {
  DRAFT
  READY
  LOCKED
  APPROVED
  CONDITIONAL
  DECLINED
  RELEASED
}

enum CommitteeDecisionOutcome {
  APPROVED
  CONDITIONAL
  DECLINED
  DEFERRED
}

model User {
  id            String            @id @default(cuid())
  name          String
  email         String            @unique
  role          UserRole          @default(ANALYST)
  isActive      Boolean           @default(true)
  sessionVersion Int              @default(1)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  valuationRuns ValuationRun[]
  documents     DocumentVersion[]
  overrides     SourceOverride[]
  approvedFeatureSnapshots AssetFeatureSnapshot[]
  reviewedEnergySnapshots         EnergySnapshot[]       @relation("EnergySnapshotReviewedBy")
  reviewedPermitSnapshots         PermitSnapshot[]       @relation("PermitSnapshotReviewedBy")
  reviewedOwnershipRecords        OwnershipRecord[]      @relation("OwnershipRecordReviewedBy")
  reviewedEncumbranceRecords      EncumbranceRecord[]    @relation("EncumbranceRecordReviewedBy")
  reviewedPlanningConstraints     PlanningConstraint[]   @relation("PlanningConstraintReviewedBy")
  reviewedLeases                  Lease[]                @relation("LeaseReviewedBy")
  adminIdentityBindings           AdminIdentityBinding[]
  adminSessions                   AdminSession[]
  adminAccessGrants               AdminAccessGrant[]
  adminProvisioningBindings       AdminProvisioningBinding[]
  reviewedInvestorReports         InvestorReport[]       @relation("InvestorReportReviewedBy")
  releasedInvestorReports         InvestorReport[]       @relation("InvestorReportReleasedBy")
  approvedResearchSnapshots       ResearchSnapshot[]     @relation("ResearchSnapshotApprovedBy")
}

model AdminIdentityBinding {
  id                 String   @id @default(cuid())
  provider           String
  subject            String
  userId             String?
  emailSnapshot      String?
  identifierSnapshot String
  lastSeenAt         DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([provider, subject])
  @@index([userId, updatedAt])
  @@index([emailSnapshot, updatedAt])
}

model AdminSession {
  id             String   @id @default(cuid())
  userId         String?
  actorIdentifier String
  role           UserRole
  provider       String   @default("session")
  subject        String?
  email          String?
  sessionVersion Int?
  expiresAt      DateTime
  revokedAt      DateTime?
  lastSeenAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt, revokedAt])
}

model AdminProvisioningBinding {
  id           String   @id @default(cuid())
  provider     String
  externalId   String
  userId       String
  emailSnapshot String?
  nameSnapshot String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@index([userId, updatedAt])
}

model AdminAccessGrant {
  id         String               @id @default(cuid())
  userId     String
  scopeType  AdminAccessScopeType
  scopeId    String
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scopeType, scopeId])
  @@index([scopeType, scopeId, updatedAt])
}

model Asset {
  id                    String            @id @default(cuid())
  assetCode             String            @unique
  slug                  String            @unique
  name                  String
  assetClass            AssetClass        @default(DATA_CENTER)
  assetType             String
  assetSubtype          String?
  market                String            @default("KR")
  status                AssetStatus       @default(INTAKE)
  stage                 AssetStage        @default(SCREENING)
  description           String
  ownerName             String?
  sponsorName           String?
  developmentSummary    String?
  targetItLoadMw        Float?
  powerCapacityMw       Float?
  landAreaSqm           Float?
  grossFloorAreaSqm     Float?
  rentableAreaSqm       Float?
  purchasePriceKrw      Float?
  occupancyAssumptionPct Float?
  stabilizedOccupancyPct Float?
  tenantAssumption      String?
  capexAssumptionKrw    Float?
  opexAssumptionKrw     Float?
  financingLtvPct       Float?
  financingRatePct      Float?
  holdingPeriodYears    Float?
  exitCapRatePct        Float?
  currentValuationKrw   Float?
  lastEnrichedAt        DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  address               Address?
  siteProfile           SiteProfile?
  buildingSnapshot      BuildingSnapshot?
  permitSnapshot        PermitSnapshot?
  energySnapshot        EnergySnapshot?
  marketSnapshot        MarketSnapshot?
  dataCenterDetail      DataCenterDetail?
  officeDetail          OfficeDetail?
  valuations            ValuationRun[]
  documents             Document[]
  inquiries             Inquiry[]
  deals                 Deal[]
  overrides             SourceOverride[]
  readinessProject      ReadinessProject?
  comparableSet         ComparableSet?
  capexLineItems        CapexLineItem[]
  leases                Lease[]
  taxAssumption         TaxAssumption?
  spvStructure          SpvStructure?
  debtFacilities        DebtFacility[]
  parcels               Parcel[]
  buildingRecords       BuildingRecord[]
  planningConstraints   PlanningConstraint[]
  ownershipRecords      OwnershipRecord[]
  encumbranceRecords    EncumbranceRecord[]
  transactionComps      TransactionComp[]
  rentComps             RentComp[]
  marketIndicatorSeries MarketIndicatorSeries[]
  macroSeries           MacroSeries[]
  macroFactors          MacroFactor[]
  realizedOutcomes      RealizedOutcome[]
  pipelineProjects      PipelineProject[]
  geoFeatures           GeoFeature[]
  satelliteScenes       SatelliteScene[]
  satelliteObservations SatelliteObservation[]
  hazardObservations    HazardObservation[]
  constructionProgressObservations ConstructionProgressObservation[]
  documentFacts         DocumentFact[]
  featureSnapshots      AssetFeatureSnapshot[]
  aiInsights            AiInsight[]
  researchSnapshots     ResearchSnapshot[]
  coverageTasks         CoverageTask[]
  counterparties        Counterparty[]
  financialStatements   FinancialStatement[]
  creditAssessments     CreditAssessment[]
  portfolioAssets       PortfolioAsset[]
  committeePackets      InvestmentCommitteePacket[]
  tokenization          TokenizedAsset?
}

model Address {
  id          String   @id @default(cuid())
  assetId      String   @unique
  line1       String
  line2       String?
  district    String?
  city        String
  province    String
  postalCode  String?
  country     String   @default("KR")
  latitude    Float?
  longitude   Float?
  parcelId    String?
  sourceLabel String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model SiteProfile {
  id               String       @id @default(cuid())
  assetId           String       @unique
  gridAvailability String
  fiberAccess      String
  latencyProfile   String
  floodRiskScore   Float?
  wildfireRiskScore Float?
  seismicRiskScore Float?
  siteNotes        String
  sourceStatus     SourceStatus @default(MANUAL)
  sourceUpdatedAt  DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  asset            Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model BuildingSnapshot {
  id                  String       @id @default(cuid())
  assetId              String       @unique
  zoning              String
  buildingCoveragePct Float?
  floorAreaRatioPct   Float?
  grossFloorAreaSqm   Float?
  structureDescription String?
  redundancyTier      String?
  coolingType         String?
  sourceStatus        SourceStatus @default(MANUAL)
  sourceUpdatedAt     DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  asset               Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model PermitSnapshot {
  id                        String       @id @default(cuid())
  assetId                    String       @unique
  permitStage               String
  zoningApprovalStatus      String
  environmentalReviewStatus String
  powerApprovalStatus       String
  timelineNotes             String
  reviewStatus              ReviewStatus @default(PENDING)
  reviewedAt                DateTime?
  reviewedById              String?
  reviewNotes               String?
  sourceStatus              SourceStatus @default(MANUAL)
  sourceUpdatedAt           DateTime?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  asset                     Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  reviewedBy                User?        @relation("PermitSnapshotReviewedBy", fields: [reviewedById], references: [id])
}

model EnergySnapshot {
  id                     String       @id @default(cuid())
  assetId                 String       @unique
  utilityName            String
  substationDistanceKm   Float?
  tariffKrwPerKwh        Float?
  renewableAvailabilityPct Float?
  pueTarget              Float?
  backupFuelHours        Float?
  reviewStatus           ReviewStatus @default(PENDING)
  reviewedAt             DateTime?
  reviewedById           String?
  reviewNotes            String?
  sourceStatus           SourceStatus @default(MANUAL)
  sourceUpdatedAt        DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  asset                  Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  reviewedBy             User?        @relation("EnergySnapshotReviewedBy", fields: [reviewedById], references: [id])
}

model MarketSnapshot {
  id                      String       @id @default(cuid())
  assetId                  String       @unique
  metroRegion             String
  vacancyPct              Float?
  colocationRatePerKwKrw  Float?
  capRatePct              Float?
  debtCostPct             Float?
  inflationPct            Float?
  constructionCostPerMwKrw Float?
  discountRatePct         Float?
  marketNotes             String?
  sourceStatus            SourceStatus @default(MANUAL)
  sourceUpdatedAt         DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  asset                   Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  dataCenterMarketDetail  DataCenterMarketDetail?
}

model DataCenterDetail {
  id                   String   @id @default(cuid())
  assetId              String   @unique
  powerCapacityMw      Float?
  targetItLoadMw       Float?
  pueTarget            Float?
  utilityName          String?
  substationDistanceKm Float?
  renewablePct         Float?
  redundancyTier       String?
  coolingType          String?
  fiberAccess          String?
  latencyProfile       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  asset                Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model OfficeDetail {
  id                           String   @id @default(cuid())
  assetId                      String   @unique
  stabilizedRentPerSqmMonthKrw Float?
  otherIncomeKrw               Float?
  vacancyAllowancePct          Float?
  creditLossPct                Float?
  tenantImprovementReserveKrw  Float?
  leasingCommissionReserveKrw  Float?
  annualCapexReserveKrw        Float?
  weightedAverageLeaseTermYears Float?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  asset                        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model DataCenterMarketDetail {
  id                       String         @id @default(cuid())
  marketSnapshotId         String         @unique
  colocationRatePerKwKrw   Float?
  constructionCostPerMwKrw Float?
  aiDemandIndex            Float?
  utilityQueueMonths       Float?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  marketSnapshot           MarketSnapshot @relation(fields: [marketSnapshotId], references: [id], onDelete: Cascade)
}

model ValuationRun {
  id               String          @id @default(cuid())
  assetId           String
  runLabel         String
  status           ValuationStatus @default(COMPLETED)
  approvalStatus   String          @default("PENDING_REVIEW")
  approvalNotes    String?
  approvedByLabel  String?
  approvedAt       DateTime?
  engineVersion    String
  confidenceScore  Float
  baseCaseValueKrw Float
  underwritingMemo String
  keyRisks         String[]
  ddChecklist      String[]
  assumptions      Json
  provenance       Json
  createdById      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  asset            Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdBy        User?           @relation(fields: [createdById], references: [id])
  scenarios        ValuationScenario[]
  sensitivityRuns  SensitivityRun[]
  aiInsights       AiInsight[]
  committeePackets InvestmentCommitteePacket[]
}

model ValuationScenario {
  id                 String       @id @default(cuid())
  valuationRunId      String
  name               String
  valuationKrw       Float
  impliedYieldPct    Float?
  exitCapRatePct     Float?
  debtServiceCoverage Float?
  notes              String
  scenarioOrder      Int
  createdAt          DateTime     @default(now())
  valuationRun       ValuationRun @relation(fields: [valuationRunId], references: [id], onDelete: Cascade)

  @@unique([valuationRunId, name])
}

model SensitivityRun {
  id                  String             @id @default(cuid())
  valuationRunId      String
  runType             String             @default("ONE_WAY")
  title               String
  baselineMetricName  String
  baselineMetricValue Float
  summary             Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  valuationRun        ValuationRun       @relation(fields: [valuationRunId], references: [id], onDelete: Cascade)
  points              SensitivityPoint[]

  @@index([valuationRunId, runType])
}

model SensitivityPoint {
  id               String         @id @default(cuid())
  sensitivityRunId String
  variableKey      String
  variableLabel    String
  shockLabel       String
  shockValue       Float?
  metricName       String
  metricValue      Float
  deltaPct         Float
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  sensitivityRun   SensitivityRun @relation(fields: [sensitivityRunId], references: [id], onDelete: Cascade)

  @@index([sensitivityRunId, sortOrder])
}

model ComparableSet {
  id              String            @id @default(cuid())
  assetId         String            @unique
  name            String
  valuationDate   DateTime?
  calibrationMode String            @default("Weighted market calibration")
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  asset           Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  entries         ComparableEntry[]
}

model ComparableEntry {
  id                  String        @id @default(cuid())
  comparableSetId     String
  label               String
  location            String
  assetType           String
  stage               AssetStage?
  sourceLink          String?
  powerCapacityMw     Float?
  grossFloorAreaSqm   Float?
  occupancyPct        Float?
  pricePerMwKrw       Float?
  valuationKrw        Float?
  monthlyRatePerKwKrw Float?
  capRatePct          Float?
  discountRatePct     Float?
  weightPct           Float?
  notes               String?
  createdAt           DateTime      @default(now())
  comparableSet       ComparableSet @relation(fields: [comparableSetId], references: [id], onDelete: Cascade)
}

model CapexLineItem {
  id         String        @id @default(cuid())
  assetId     String
  category   CapexCategory
  label      String
  amountKrw  Float
  spendYear  Int           @default(0)
  isEmbedded Boolean       @default(false)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  asset      Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model Lease {
  id                   String       @id @default(cuid())
  assetId               String
  tenantName           String
  status               LeaseStatus  @default(PIPELINE)
  leasedKw             Float
  startYear            Int          @default(1)
  termYears            Int
  baseRatePerKwKrw     Float
  annualEscalationPct  Float?
  probabilityPct       Float?
  renewProbabilityPct  Float?
  downtimeMonths       Int?
  rolloverDowntimeMonths Int?
  rentFreeMonths       Int?
  renewalRentFreeMonths Int?
  renewalTermYears     Int?
  renewalCount         Int?
  markToMarketRatePerKwKrw Float?
  renewalTenantImprovementKrw Float?
  renewalLeasingCommissionKrw Float?
  tenantImprovementKrw Float?
  leasingCommissionKrw Float?
  recoverableOpexRatioPct Float?
  fixedRecoveriesKrw   Float?
  expenseStopKrwPerKwMonth Float?
  utilityPassThroughPct Float?
  fitOutCostKrw        Float?
  notes                String?
  reviewStatus         ReviewStatus @default(PENDING)
  reviewedAt           DateTime?
  reviewedById         String?
  reviewNotes          String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  asset                Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  steps                LeaseStep[]
  reviewedBy           User?        @relation("LeaseReviewedBy", fields: [reviewedById], references: [id])
}

model LeaseStep {
  id                  String   @id @default(cuid())
  leaseId              String
  stepOrder           Int
  startYear           Int
  endYear             Int
  ratePerKwKrw        Float
  leasedKw            Float?
  annualEscalationPct Float?
  occupancyPct        Float?
  rentFreeMonths      Int?
  renewProbabilityPct Float?
  rolloverDowntimeMonths Int?
  renewalRentFreeMonths Int?
  renewalTermYears    Int?
  renewalCount        Int?
  markToMarketRatePerKwKrw Float?
  renewalTenantImprovementKrw Float?
  renewalLeasingCommissionKrw Float?
  tenantImprovementKrw Float?
  leasingCommissionKrw Float?
  recoverableOpexRatioPct Float?
  fixedRecoveriesKrw  Float?
  expenseStopKrwPerKwMonth Float?
  utilityPassThroughPct Float?
  notes               String?
  createdAt           DateTime @default(now())
  lease               Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@unique([leaseId, stepOrder])
}

model TaxAssumption {
  id                 String   @id @default(cuid())
  assetId             String   @unique
  acquisitionTaxPct  Float?
  vatRecoveryPct     Float?
  propertyTaxPct     Float?
  insurancePct       Float?
  corporateTaxPct    Float?
  withholdingTaxPct  Float?
  exitTaxPct         Float?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  asset              Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model SpvStructure {
  id                    String   @id @default(cuid())
  assetId                String   @unique
  legalStructure        String
  managementFeePct      Float?
  performanceFeePct     Float?
  promoteThresholdPct   Float?
  promoteSharePct       Float?
  reserveTargetMonths   Float?
  distributionWaterfall String?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  asset                 Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model DebtFacility {
  id                     String               @id @default(cuid())
  assetId                 String
  facilityType           DebtFacilityType
  lenderName             String?
  commitmentKrw          Float
  drawnAmountKrw         Float?
  interestRatePct        Float
  upfrontFeePct          Float?
  commitmentFeePct       Float?
  gracePeriodMonths      Int?
  amortizationTermMonths Int?
  amortizationProfile    AmortizationProfile  @default(INTEREST_ONLY)
  sculptedTargetDscr     Float?
  balloonPct             Float?
  reserveMonths          Float?
  notes                  String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  asset                  Asset                @relation(fields: [assetId], references: [id], onDelete: Cascade)
  draws                  DebtDraw[]
  covenantTests          CovenantTest[]
}

model DebtDraw {
  id             String       @id @default(cuid())
  debtFacilityId String
  drawYear       Int
  drawMonth      Int?
  amountKrw      Float
  notes          String?
  createdAt      DateTime     @default(now())
  debtFacility   DebtFacility @relation(fields: [debtFacilityId], references: [id], onDelete: Cascade)
}

model Document {
