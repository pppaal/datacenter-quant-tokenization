  reviewNotes          String?
  sourceSystem         String
  sourceStatus         SourceStatus @default(MANUAL)
  sourceUpdatedAt      DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  asset                Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  reviewedBy           User?        @relation("EncumbranceRecordReviewedBy", fields: [reviewedById], references: [id])

  @@index([assetId, encumbranceType, effectiveDate])
}

model TransactionComp {
  id              String       @id @default(cuid())
  assetId         String?
  market          String
  region          String
  comparableType  String
  transactionDate DateTime?
  priceKrw        Float?
  pricePerSqmKrw  Float?
  pricePerMwKrw   Float?
  capRatePct      Float?
  buyerType       String?
  sellerType      String?
  sourceLink      String?
  sourceSystem    String
  sourceStatus    SourceStatus @default(MANUAL)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  asset           Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([assetId, transactionDate])
  @@index([market, region, transactionDate])
}

model RentComp {
  id                   String       @id @default(cuid())
  assetId              String?
  market               String
  region               String
  comparableType       String
  observationDate      DateTime?
  monthlyRentPerSqmKrw Float?
  monthlyRatePerKwKrw  Float?
  occupancyPct         Float?
  escalationPct        Float?
  sourceLink           String?
  sourceSystem         String
  sourceStatus         SourceStatus @default(MANUAL)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  asset                Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([assetId, observationDate])
  @@index([market, region, observationDate])
}

model MarketIndicatorSeries {
  id              String       @id @default(cuid())
  assetId         String?
  market          String
  region          String?
  indicatorKey    String
  observationDate DateTime
  value           Float?
  unit            String?
  sourceSystem    String
  sourceStatus    SourceStatus @default(MANUAL)
  createdAt       DateTime     @default(now())
  asset           Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([assetId, indicatorKey, observationDate])
  @@index([market, region, indicatorKey, observationDate])
}

model MacroSeries {
  id              String       @id @default(cuid())
  assetId         String?
  market          String
  seriesKey       String
  label           String
  frequency       String       @default("monthly")
  observationDate DateTime
  value           Float
  unit            String?
  sourceSystem    String       @default("manual")
  sourceStatus    SourceStatus @default(MANUAL)
  sourceUpdatedAt DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  asset           Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@unique([market, seriesKey, observationDate, assetId])
  @@index([market, seriesKey, observationDate])
}

model MacroFactor {
  id              String       @id @default(cuid())
  assetId         String?
  market          String
  factorKey       String
  label           String
  observationDate DateTime
  value           Float
  unit            String?
  direction       String
  commentary      String?
  sourceSystem    String       @default("macro-factor-engine")
  sourceStatus    SourceStatus @default(MANUAL)
  sourceUpdatedAt DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  asset           Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@unique([market, factorKey, observationDate, assetId])
  @@index([market, factorKey, observationDate])
}

model RealizedOutcome {
  id                  String       @id @default(cuid())
  assetId             String
  observationDate     DateTime
  occupancyPct        Float?
  noiKrw              Float?
  rentGrowthPct       Float?
  valuationKrw        Float?
  debtServiceCoverage Float?
  exitCapRatePct      Float?
  notes               String?
  sourceSystem        String       @default("manual_realized_capture")
  sourceStatus        SourceStatus @default(MANUAL)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  asset               Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, observationDate])
  @@index([assetId, observationDate])
}

model MacroProfileOverride {
  id                          String      @id @default(cuid())
  assetClass                  AssetClass?
  country                     String?
  submarketPattern            String?
  label                       String
  capitalRateMultiplier       Float?
  liquidityMultiplier         Float?
  leasingMultiplier           Float?
  constructionMultiplier      Float?
  priority                    Int         @default(100)
  isActive                    Boolean     @default(true)
  notes                       String?
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt

  @@index([isActive, priority])
  @@index([country, assetClass])
}

model PipelineProject {
  id                   String       @id @default(cuid())
  assetId              String?
  projectName          String
  market               String
  region               String?
  stageLabel           String?
  expectedDeliveryDate DateTime?
  expectedPowerMw      Float?
  expectedAreaSqm      Float?
  sponsorName          String?
  sourceLink           String?
  sourceSystem         String
  sourceStatus         SourceStatus @default(MANUAL)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  asset                Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([market, region, expectedDeliveryDate])
}

model GeoFeature {
  id              String       @id @default(cuid())
  assetId         String
  featureType     String
  featureKey      String
  valueText       String?
  valueNumber     Float?
  unit            String?
  geometryRef     String?
  sourceSystem    String
  sourceStatus    SourceStatus @default(MANUAL)
  sourceUpdatedAt DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  asset           Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, featureType, featureKey])
}

model SatelliteScene {
  id                                 String                          @id @default(cuid())
  assetId                            String?
  sourceSystem                       String
  sceneIdentifier                    String
  capturedAt                         DateTime
  cloudCoverPct                      Float?
  resolutionMeters                   Float?
  sceneUrl                           String?
  footprintRef                       String?
  metadata                           Json?
  createdAt                          DateTime                        @default(now())
  asset                              Asset?                          @relation(fields: [assetId], references: [id], onDelete: SetNull)
  observations                       SatelliteObservation[]
  hazardObservations                 HazardObservation[]
  constructionProgressObservations   ConstructionProgressObservation[]

  @@unique([sourceSystem, sceneIdentifier])
  @@index([assetId, capturedAt])
}

model SatelliteObservation {
  id               String          @id @default(cuid())
  assetId          String
  satelliteSceneId String?
  observationDate  DateTime
  metricKey        String
  metricValue      Float?
  metricText       String?
  unit             String?
  geometryRef      String?
  rasterRef        String?
  sourceSystem     String
  freshnessLabel   String?
  createdAt        DateTime        @default(now())
  asset            Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  satelliteScene   SatelliteScene? @relation(fields: [satelliteSceneId], references: [id], onDelete: SetNull)

  @@index([assetId, metricKey, observationDate])
}

model HazardObservation {
  id               String          @id @default(cuid())
  assetId          String
  satelliteSceneId String?
  hazardType       String
  observationDate  DateTime
  score            Float?
  value            Float?
  unit             String?
  geometryRef      String?
  rasterRef        String?
  sourceSystem     String
  sourceSceneId    String?
  freshnessLabel   String?
  createdAt        DateTime        @default(now())
  asset            Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  satelliteScene   SatelliteScene? @relation(fields: [satelliteSceneId], references: [id], onDelete: SetNull)

  @@index([assetId, hazardType, observationDate])
}

model ConstructionProgressObservation {
  id               String          @id @default(cuid())
  assetId          String
  satelliteSceneId String?
  observationDate  DateTime
  progressPct      Float?
  changeScore      Float?
  confidenceScore  Float?
  method           String
  imageRef         String?
  note             String?
  sourceSystem     String
  createdAt        DateTime        @default(now())
  asset            Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  satelliteScene   SatelliteScene? @relation(fields: [satelliteSceneId], references: [id], onDelete: SetNull)

  @@index([assetId, observationDate])
}

model DocumentExtractionRun {
  id               String          @id @default(cuid())
  documentVersionId String
  modelName        String
  taskType         String
  status           String
  rawOutput        Json?
  structuredOutput Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  documentVersion  DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  facts            DocumentFact[]

  @@index([documentVersionId, taskType, createdAt])
}

model DocumentChunk {
  id                 String          @id @default(cuid())
  documentVersionId  String
  chunkIndex         Int
  text               String
  embeddingModel     String?
  embeddingVectorRef String?
  pageNumber         Int?
  createdAt          DateTime        @default(now())
  documentVersion    DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)

  @@unique([documentVersionId, chunkIndex])
}

model DocumentFact {
  id                String                 @id @default(cuid())
  assetId           String?
  documentVersionId String
  factType          String
  factKey           String
  factValueText     String?
  factValueNumber   Float?
  factValueDate     DateTime?
  unit              String?
  confidenceScore   Float?
  extractionRunId   String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  asset             Asset?                 @relation(fields: [assetId], references: [id], onDelete: SetNull)
  documentVersion   DocumentVersion        @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  extractionRun     DocumentExtractionRun? @relation(fields: [extractionRunId], references: [id], onDelete: SetNull)

  @@index([assetId, factType, factKey])
  @@index([documentVersionId, factType])
}

model AssetFeatureSnapshot {
  id               String         @id @default(cuid())
  assetId          String
  snapshotDate     DateTime       @default(now())
  featureNamespace String
  sourceVersion    String?
  approvedById     String?
  createdAt        DateTime       @default(now())
  asset            Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  approvedBy       User?          @relation(fields: [approvedById], references: [id])
  values           FeatureValue[]

  @@index([assetId, featureNamespace, snapshotDate])
}

model FeatureValue {
  id                     String               @id @default(cuid())
  assetFeatureSnapshotId String
  key                    String
  numberValue            Float?
  textValue              String?
  jsonValue              Json?
  unit                   String?
  sourceRef              String?
  createdAt              DateTime             @default(now())
  snapshot               AssetFeatureSnapshot @relation(fields: [assetFeatureSnapshotId], references: [id], onDelete: Cascade)

  @@index([assetFeatureSnapshotId, key])
}

model AiInsight {
  id                String           @id @default(cuid())
  assetId           String?
  valuationRunId    String?
  documentVersionId String?
  insightType       String
  title             String?
  content           String
  evidence          Json?
  modelName         String
  status            String
  createdAt         DateTime         @default(now())
  asset             Asset?           @relation(fields: [assetId], references: [id], onDelete: SetNull)
  valuationRun      ValuationRun?    @relation(fields: [valuationRunId], references: [id], onDelete: SetNull)
  documentVersion   DocumentVersion? @relation(fields: [documentVersionId], references: [id], onDelete: SetNull)

  @@index([assetId, insightType, createdAt])
  @@index([valuationRunId, insightType])
}

model Inquiry {
  id          String   @id @default(cuid())
  assetId      String?
  name        String
  company     String
  email       String
  requestType String
  message     String
  status      String   @default("NEW")
  createdAt   DateTime @default(now())
  asset       Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
}

model SourceCache {
  id            String       @id @default(cuid())
  sourceKey     String
  sourceSystem  String
  cacheKey      String
  status        SourceStatus
  payload       Json
  fetchedAt     DateTime     @default(now())
  expiresAt     DateTime
  freshnessLabel String
  errorMessage  String?
  attempts      Int          @default(1)

  @@unique([sourceSystem, cacheKey])
}

model SourceOverride {
  id           String   @id @default(cuid())
  sourceSystem String
  cacheKey     String
  assetId      String?
  payload      Json
  note         String?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  asset        Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  createdBy    User?    @relation(fields: [createdById], references: [id])

  @@unique([sourceSystem, cacheKey])
}

model ReadinessProject {
  id              String          @id @default(cuid())
  assetId         String          @unique
  readinessStatus ReadinessStatus @default(NOT_STARTED) @map("registryStatus")
  packageName     String          @map("registryName")
  chainName       String?
  reviewPhase     String          @map("tokenizationPhase")
  legalStructure  String?
  nextAction      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  asset           Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  onchainRecords  OnchainRecord[]

  @@map("RwaProject")
}

model OnchainRecord {
  id                 String          @id @default(cuid())
  readinessProjectId String          @map("rwaProjectId")
  documentId         String?
  recordType         String
  txHash             String?
  chainId            String?
  status             ReadinessStatus @default(NOT_STARTED)
  payload            Json
  anchoredAt         DateTime?
  createdAt          DateTime        @default(now())
  readinessProject   ReadinessProject @relation(fields: [readinessProjectId], references: [id], onDelete: Cascade)
  document           Document?       @relation(fields: [documentId], references: [id], onDelete: SetNull)
}

model AuditEvent {
  id              String   @id @default(cuid())
  actorIdentifier String
  actorRole       String
  action          String
  entityType      String
  entityId        String?
  assetId         String?
  requestPath     String?
  requestMethod   String?
  ipAddress       String?
  statusLabel     String   @default("SUCCESS")
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([actorIdentifier, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([assetId, createdAt])
}

model SequenceCounter {
  key       String   @id
  nextValue Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
