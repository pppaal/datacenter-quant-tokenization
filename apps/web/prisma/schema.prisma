generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ANALYST
  VIEWER
}

enum AssetStage {
  SCREENING
  LAND_SECURED
  POWER_REVIEW
  PERMITTING
  CONSTRUCTION
  LIVE
  STABILIZED
}

enum AssetStatus {
  INTAKE
  ENRICHING
  UNDER_REVIEW
  IC_READY
  APPROVED
  DECLINED
  ON_HOLD
}

enum AssetClass {
  OFFICE
  INDUSTRIAL
  RETAIL
  MULTIFAMILY
  HOTEL
  DATA_CENTER
  LAND
  MIXED_USE
}

enum DocumentType {
  IM
  POWER_STUDY
  PERMIT
  LEASE
  MODEL
  SITE_PHOTO
  GRID_NOTICE
  REPORT
  OTHER
}

enum SourceStatus {
  FRESH
  STALE
  FAILED
  MANUAL
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ValuationStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum ReadinessStatus {
  NOT_STARTED
  READY
  ANCHORED
  ERROR

  @@map("RegistryStatus")
}

enum CapexCategory {
  LAND
  SHELL_CORE
  ELECTRICAL
  MECHANICAL
  IT_FIT_OUT
  SOFT_COST
  CONTINGENCY
}

enum LeaseStatus {
  PIPELINE
  SIGNED
  ACTIVE
  EXPIRED
}

enum DebtFacilityType {
  CONSTRUCTION
  TERM
  REVOLVER
}

enum AmortizationProfile {
  INTEREST_ONLY
  MORTGAGE
  SCULPTED
  BULLET
}

enum DealStage {
  SOURCED
  SCREENED
  NDA
  LOI
  DD
  IC
  CLOSING
  ASSET_MANAGEMENT
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActivityType {
  GENERAL
  NOTE
  STAGE_CHANGED
  NEXT_ACTION
  TASK_CREATED
  TASK_UPDATED
  RISK_CREATED
  RISK_UPDATED
  COUNTERPARTY_ADDED
}

enum DealRequestStatus {
  REQUESTED
  RECEIVED
  WAIVED
}

enum DealBidStatus {
  DRAFT
  SUBMITTED
  COUNTERED
  BAFO
  ACCEPTED
  DECLINED
  WITHDRAWN
}

enum DealLenderQuoteStatus {
  INDICATED
  TERM_SHEET
  CREDIT_APPROVED
  DECLINED
  WITHDRAWN
  CLOSED
}

enum DealNegotiationEventType {
  SELLER_COUNTER
  BUYER_FEEDBACK
  EXCLUSIVITY_GRANTED
  EXCLUSIVITY_EXTENDED
  PROCESS_UPDATE
}

model User {
  id            String            @id @default(cuid())
  name          String
  email         String            @unique
  role          UserRole          @default(ANALYST)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  valuationRuns ValuationRun[]
  documents     DocumentVersion[]
  overrides     SourceOverride[]
  approvedFeatureSnapshots AssetFeatureSnapshot[]
  reviewedEnergySnapshots         EnergySnapshot[]       @relation("EnergySnapshotReviewedBy")
  reviewedPermitSnapshots         PermitSnapshot[]       @relation("PermitSnapshotReviewedBy")
  reviewedOwnershipRecords        OwnershipRecord[]      @relation("OwnershipRecordReviewedBy")
  reviewedEncumbranceRecords      EncumbranceRecord[]    @relation("EncumbranceRecordReviewedBy")
  reviewedPlanningConstraints     PlanningConstraint[]   @relation("PlanningConstraintReviewedBy")
  reviewedLeases                  Lease[]                @relation("LeaseReviewedBy")
}

model Asset {
  id                    String            @id @default(cuid())
  assetCode             String            @unique
  slug                  String            @unique
  name                  String
  assetClass            AssetClass        @default(DATA_CENTER)
  assetType             String
  assetSubtype          String?
  market                String            @default("KR")
  status                AssetStatus       @default(INTAKE)
  stage                 AssetStage        @default(SCREENING)
  description           String
  ownerName             String?
  sponsorName           String?
  developmentSummary    String?
  targetItLoadMw        Float?
  powerCapacityMw       Float?
  landAreaSqm           Float?
  grossFloorAreaSqm     Float?
  rentableAreaSqm       Float?
  purchasePriceKrw      Float?
  occupancyAssumptionPct Float?
  stabilizedOccupancyPct Float?
  tenantAssumption      String?
  capexAssumptionKrw    Float?
  opexAssumptionKrw     Float?
  financingLtvPct       Float?
  financingRatePct      Float?
  holdingPeriodYears    Float?
  exitCapRatePct        Float?
  currentValuationKrw   Float?
  lastEnrichedAt        DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  address               Address?
  siteProfile           SiteProfile?
  buildingSnapshot      BuildingSnapshot?
  permitSnapshot        PermitSnapshot?
  energySnapshot        EnergySnapshot?
  marketSnapshot        MarketSnapshot?
  dataCenterDetail      DataCenterDetail?
  officeDetail          OfficeDetail?
  valuations            ValuationRun[]
  documents             Document[]
  inquiries             Inquiry[]
  deals                 Deal[]
  overrides             SourceOverride[]
  readinessProject      ReadinessProject?
  comparableSet         ComparableSet?
  capexLineItems        CapexLineItem[]
  leases                Lease[]
  taxAssumption         TaxAssumption?
  spvStructure          SpvStructure?
  debtFacilities        DebtFacility[]
  parcels               Parcel[]
  buildingRecords       BuildingRecord[]
  planningConstraints   PlanningConstraint[]
  ownershipRecords      OwnershipRecord[]
  encumbranceRecords    EncumbranceRecord[]
  transactionComps      TransactionComp[]
  rentComps             RentComp[]
  marketIndicatorSeries MarketIndicatorSeries[]
  macroSeries           MacroSeries[]
  macroFactors          MacroFactor[]
  realizedOutcomes      RealizedOutcome[]
  pipelineProjects      PipelineProject[]
  geoFeatures           GeoFeature[]
  satelliteScenes       SatelliteScene[]
  satelliteObservations SatelliteObservation[]
  hazardObservations    HazardObservation[]
  constructionProgressObservations ConstructionProgressObservation[]
  documentFacts         DocumentFact[]
  featureSnapshots      AssetFeatureSnapshot[]
  aiInsights            AiInsight[]
  counterparties        Counterparty[]
  financialStatements   FinancialStatement[]
  creditAssessments     CreditAssessment[]
}

model Address {
  id          String   @id @default(cuid())
  assetId      String   @unique
  line1       String
  line2       String?
  district    String?
  city        String
  province    String
  postalCode  String?
  country     String   @default("KR")
  latitude    Float?
  longitude   Float?
  parcelId    String?
  sourceLabel String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model SiteProfile {
  id               String       @id @default(cuid())
  assetId           String       @unique
  gridAvailability String
  fiberAccess      String
  latencyProfile   String
  floodRiskScore   Float?
  wildfireRiskScore Float?
  seismicRiskScore Float?
  siteNotes        String
  sourceStatus     SourceStatus @default(MANUAL)
  sourceUpdatedAt  DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  asset            Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model BuildingSnapshot {
  id                  String       @id @default(cuid())
  assetId              String       @unique
  zoning              String
  buildingCoveragePct Float?
  floorAreaRatioPct   Float?
  grossFloorAreaSqm   Float?
  structureDescription String?
  redundancyTier      String?
  coolingType         String?
  sourceStatus        SourceStatus @default(MANUAL)
  sourceUpdatedAt     DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  asset               Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model PermitSnapshot {
  id                        String       @id @default(cuid())
  assetId                    String       @unique
  permitStage               String
  zoningApprovalStatus      String
  environmentalReviewStatus String
  powerApprovalStatus       String
  timelineNotes             String
  reviewStatus              ReviewStatus @default(PENDING)
  reviewedAt                DateTime?
  reviewedById              String?
  reviewNotes               String?
  sourceStatus              SourceStatus @default(MANUAL)
  sourceUpdatedAt           DateTime?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  asset                     Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  reviewedBy                User?        @relation("PermitSnapshotReviewedBy", fields: [reviewedById], references: [id])
}

model EnergySnapshot {
  id                     String       @id @default(cuid())
  assetId                 String       @unique
  utilityName            String
  substationDistanceKm   Float?
  tariffKrwPerKwh        Float?
  renewableAvailabilityPct Float?
  pueTarget              Float?
  backupFuelHours        Float?
  reviewStatus           ReviewStatus @default(PENDING)
  reviewedAt             DateTime?
  reviewedById           String?
  reviewNotes            String?
  sourceStatus           SourceStatus @default(MANUAL)
  sourceUpdatedAt        DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  asset                  Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  reviewedBy             User?        @relation("EnergySnapshotReviewedBy", fields: [reviewedById], references: [id])
}

model MarketSnapshot {
  id                      String       @id @default(cuid())
  assetId                  String       @unique
  metroRegion             String
  vacancyPct              Float?
  colocationRatePerKwKrw  Float?
  capRatePct              Float?
  debtCostPct             Float?
  inflationPct            Float?
  constructionCostPerMwKrw Float?
  discountRatePct         Float?
  marketNotes             String?
  sourceStatus            SourceStatus @default(MANUAL)
  sourceUpdatedAt         DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  asset                   Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  dataCenterMarketDetail  DataCenterMarketDetail?
}

model DataCenterDetail {
  id                   String   @id @default(cuid())
  assetId              String   @unique
  powerCapacityMw      Float?
  targetItLoadMw       Float?
  pueTarget            Float?
  utilityName          String?
  substationDistanceKm Float?
  renewablePct         Float?
  redundancyTier       String?
  coolingType          String?
  fiberAccess          String?
  latencyProfile       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  asset                Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model OfficeDetail {
  id                           String   @id @default(cuid())
  assetId                      String   @unique
  stabilizedRentPerSqmMonthKrw Float?
  otherIncomeKrw               Float?
  vacancyAllowancePct          Float?
  creditLossPct                Float?
  tenantImprovementReserveKrw  Float?
  leasingCommissionReserveKrw  Float?
  annualCapexReserveKrw        Float?
  weightedAverageLeaseTermYears Float?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  asset                        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model DataCenterMarketDetail {
  id                       String         @id @default(cuid())
  marketSnapshotId         String         @unique
  colocationRatePerKwKrw   Float?
  constructionCostPerMwKrw Float?
  aiDemandIndex            Float?
  utilityQueueMonths       Float?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  marketSnapshot           MarketSnapshot @relation(fields: [marketSnapshotId], references: [id], onDelete: Cascade)
}

model ValuationRun {
  id               String          @id @default(cuid())
  assetId           String
  runLabel         String
  status           ValuationStatus @default(COMPLETED)
  approvalStatus   String          @default("PENDING_REVIEW")
  approvalNotes    String?
  approvedByLabel  String?
  approvedAt       DateTime?
  engineVersion    String
  confidenceScore  Float
  baseCaseValueKrw Float
  underwritingMemo String
  keyRisks         String[]
  ddChecklist      String[]
  assumptions      Json
  provenance       Json
  createdById      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  asset            Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdBy        User?           @relation(fields: [createdById], references: [id])
  scenarios        ValuationScenario[]
  sensitivityRuns  SensitivityRun[]
  aiInsights       AiInsight[]
}

model ValuationScenario {
  id                 String       @id @default(cuid())
  valuationRunId      String
  name               String
  valuationKrw       Float
  impliedYieldPct    Float?
  exitCapRatePct     Float?
  debtServiceCoverage Float?
  notes              String
  scenarioOrder      Int
  createdAt          DateTime     @default(now())
  valuationRun       ValuationRun @relation(fields: [valuationRunId], references: [id], onDelete: Cascade)

  @@unique([valuationRunId, name])
}

model SensitivityRun {
  id                  String             @id @default(cuid())
  valuationRunId      String
  runType             String             @default("ONE_WAY")
  title               String
  baselineMetricName  String
  baselineMetricValue Float
  summary             Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  valuationRun        ValuationRun       @relation(fields: [valuationRunId], references: [id], onDelete: Cascade)
  points              SensitivityPoint[]

  @@index([valuationRunId, runType])
}

model SensitivityPoint {
  id               String         @id @default(cuid())
  sensitivityRunId String
  variableKey      String
  variableLabel    String
  shockLabel       String
  shockValue       Float?
  metricName       String
  metricValue      Float
  deltaPct         Float
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  sensitivityRun   SensitivityRun @relation(fields: [sensitivityRunId], references: [id], onDelete: Cascade)

  @@index([sensitivityRunId, sortOrder])
}

model ComparableSet {
  id              String            @id @default(cuid())
  assetId         String            @unique
  name            String
  valuationDate   DateTime?
  calibrationMode String            @default("Weighted market calibration")
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  asset           Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  entries         ComparableEntry[]
}

model ComparableEntry {
  id                  String        @id @default(cuid())
  comparableSetId     String
  label               String
  location            String
  assetType           String
  stage               AssetStage?
  sourceLink          String?
  powerCapacityMw     Float?
  grossFloorAreaSqm   Float?
  occupancyPct        Float?
  pricePerMwKrw       Float?
  valuationKrw        Float?
  monthlyRatePerKwKrw Float?
  capRatePct          Float?
  discountRatePct     Float?
  weightPct           Float?
  notes               String?
  createdAt           DateTime      @default(now())
  comparableSet       ComparableSet @relation(fields: [comparableSetId], references: [id], onDelete: Cascade)
}

model CapexLineItem {
  id         String        @id @default(cuid())
  assetId     String
  category   CapexCategory
  label      String
  amountKrw  Float
  spendYear  Int           @default(0)
  isEmbedded Boolean       @default(false)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  asset      Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model Lease {
  id                   String       @id @default(cuid())
  assetId               String
  tenantName           String
  status               LeaseStatus  @default(PIPELINE)
  leasedKw             Float
  startYear            Int          @default(1)
  termYears            Int
  baseRatePerKwKrw     Float
  annualEscalationPct  Float?
  probabilityPct       Float?
  renewProbabilityPct  Float?
  downtimeMonths       Int?
  rolloverDowntimeMonths Int?
  rentFreeMonths       Int?
  renewalRentFreeMonths Int?
  renewalTermYears     Int?
  renewalCount         Int?
  markToMarketRatePerKwKrw Float?
  renewalTenantImprovementKrw Float?
  renewalLeasingCommissionKrw Float?
  tenantImprovementKrw Float?
  leasingCommissionKrw Float?
  recoverableOpexRatioPct Float?
  fixedRecoveriesKrw   Float?
  expenseStopKrwPerKwMonth Float?
  utilityPassThroughPct Float?
  fitOutCostKrw        Float?
  notes                String?
  reviewStatus         ReviewStatus @default(PENDING)
  reviewedAt           DateTime?
  reviewedById         String?
  reviewNotes          String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  asset                Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  steps                LeaseStep[]
  reviewedBy           User?        @relation("LeaseReviewedBy", fields: [reviewedById], references: [id])
}

model LeaseStep {
  id                  String   @id @default(cuid())
  leaseId              String
  stepOrder           Int
  startYear           Int
  endYear             Int
  ratePerKwKrw        Float
  leasedKw            Float?
  annualEscalationPct Float?
  occupancyPct        Float?
  rentFreeMonths      Int?
  renewProbabilityPct Float?
  rolloverDowntimeMonths Int?
  renewalRentFreeMonths Int?
  renewalTermYears    Int?
  renewalCount        Int?
  markToMarketRatePerKwKrw Float?
  renewalTenantImprovementKrw Float?
  renewalLeasingCommissionKrw Float?
  tenantImprovementKrw Float?
  leasingCommissionKrw Float?
  recoverableOpexRatioPct Float?
  fixedRecoveriesKrw  Float?
  expenseStopKrwPerKwMonth Float?
  utilityPassThroughPct Float?
  notes               String?
  createdAt           DateTime @default(now())
  lease               Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@unique([leaseId, stepOrder])
}

model TaxAssumption {
  id                 String   @id @default(cuid())
  assetId             String   @unique
  acquisitionTaxPct  Float?
  vatRecoveryPct     Float?
  propertyTaxPct     Float?
  insurancePct       Float?
  corporateTaxPct    Float?
  withholdingTaxPct  Float?
  exitTaxPct         Float?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  asset              Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model SpvStructure {
  id                    String   @id @default(cuid())
  assetId                String   @unique
  legalStructure        String
  managementFeePct      Float?
  performanceFeePct     Float?
  promoteThresholdPct   Float?
  promoteSharePct       Float?
  reserveTargetMonths   Float?
  distributionWaterfall String?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  asset                 Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model DebtFacility {
  id                     String               @id @default(cuid())
  assetId                 String
  facilityType           DebtFacilityType
  lenderName             String?
  commitmentKrw          Float
  drawnAmountKrw         Float?
  interestRatePct        Float
  upfrontFeePct          Float?
  commitmentFeePct       Float?
  gracePeriodMonths      Int?
  amortizationTermMonths Int?
  amortizationProfile    AmortizationProfile  @default(INTEREST_ONLY)
  sculptedTargetDscr     Float?
  balloonPct             Float?
  reserveMonths          Float?
  notes                  String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  asset                  Asset                @relation(fields: [assetId], references: [id], onDelete: Cascade)
  draws                  DebtDraw[]
}

model DebtDraw {
  id             String       @id @default(cuid())
  debtFacilityId String
  drawYear       Int
  drawMonth      Int?
  amountKrw      Float
  notes          String?
  createdAt      DateTime     @default(now())
  debtFacility   DebtFacility @relation(fields: [debtFacilityId], references: [id], onDelete: Cascade)
}

model Document {
  id                String       @id @default(cuid())
  assetId            String
  title             String
  documentType      DocumentType @default(OTHER)
  currentVersion    Int          @default(1)
  sourceLink        String?
  aiSummary         String?
  documentHash      String
  latestStoragePath String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  asset             Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  versions          DocumentVersion[]
  onchainRecords    OnchainRecord[]
  dealRequests      DealDocumentRequest[]
}

model DocumentVersion {
  id            String   @id @default(cuid())
  documentId     String
  versionNumber Int
  fileName      String
  fileType      String
  fileSize      Int
  storagePath   String
  sourceLink    String?
  extractedText String?
  aiSummary     String?
  documentHash  String
  uploadedById  String?
  createdAt     DateTime @default(now())
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy    User?    @relation(fields: [uploadedById], references: [id])
  extractionRuns DocumentExtractionRun[]
  chunks        DocumentChunk[]
  facts         DocumentFact[]
  aiInsights    AiInsight[]
  financialStatements FinancialStatement[]
  creditAssessments   CreditAssessment[]

  @@unique([documentId, versionNumber])
}

model Counterparty {
  id                  String               @id @default(cuid())
  assetId             String?
  dealId              String?
  name                String
  role                String
  shortName           String?
  company             String?
  email               String?
  phone               String?
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  asset               Asset?               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  deal                Deal?                @relation(fields: [dealId], references: [id], onDelete: Cascade)
  financialStatements FinancialStatement[]
  creditAssessments   CreditAssessment[]
  activityLogs        ActivityLog[]
  documentRequests    DealDocumentRequest[]
  bidRevisions        DealBidRevision[]
  lenderQuotes        DealLenderQuote[]
  negotiationEvents   DealNegotiationEvent[]

  @@index([assetId, role, createdAt])
  @@index([dealId, role, createdAt])
}

model Deal {
  id               String        @id @default(cuid())
  dealCode         String        @unique
  slug             String        @unique
  title            String
  stage            DealStage     @default(SOURCED)
  market           String        @default("KR")
  city             String?
  country          String?
  assetClass       AssetClass?
  strategy         String?
  headline         String?
  nextAction       String?
  nextActionAt     DateTime?
  targetCloseDate  DateTime?
  sellerGuidanceKrw Float?
  bidGuidanceKrw   Float?
  purchasePriceKrw Float?
  statusLabel      String        @default("ACTIVE")
  archivedAt       DateTime?
  closedAt         DateTime?
  closeOutcome     String?
  closeSummary     String?
  dealLead         String?
  assetId          String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  asset            Asset?        @relation(fields: [assetId], references: [id], onDelete: SetNull)
  counterparties   Counterparty[]
  tasks            Task[]
  documentRequests DealDocumentRequest[]
  bidRevisions     DealBidRevision[]
  lenderQuotes     DealLenderQuote[]
  negotiationEvents DealNegotiationEvent[]
  riskFlags        RiskFlag[]
  activityLogs     ActivityLog[]
  probabilitySnapshots DealExecutionProbabilitySnapshot[]

  @@index([stage, targetCloseDate])
  @@index([market, assetClass, stage])
}

model DealExecutionProbabilitySnapshot {
  id                     String    @id @default(cuid())
  dealId                 String
  stage                  DealStage
  snapshotReason         String
  readinessScorePct      Float
  readinessBlockerCount  Int
  closeProbabilityPct    Float
  closeProbabilityBand   String
  headline               String
  openRiskCount          Int
  overdueTaskCount       Int
  pendingSuggestedRequestCount Int @default(0)
  hasAcceptedBid         Boolean   @default(false)
  hasApprovedFinancing   Boolean   @default(false)
  hasLiveExclusivity     Boolean   @default(false)
  createdAt              DateTime  @default(now())
  deal                   Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, createdAt])
  @@index([dealId, closeProbabilityBand, createdAt])
}

model DealDocumentRequest {
  id             String            @id @default(cuid())
  dealId         String
  counterpartyId String?
  documentId     String?
  title          String
  category       String?
  status         DealRequestStatus @default(REQUESTED)
  priority       TaskPriority      @default(MEDIUM)
  dueDate        DateTime?
  requestedAt    DateTime          @default(now())
  receivedAt     DateTime?
  matchSuggestion Json?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deal           Deal              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  counterparty   Counterparty?     @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)
  document       Document?         @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([dealId, status, dueDate])
  @@index([counterpartyId, createdAt])
  @@index([documentId, createdAt])
}

model DealBidRevision {
  id                String        @id @default(cuid())
  dealId            String
  counterpartyId    String?
  label             String
  status            DealBidStatus @default(DRAFT)
  bidPriceKrw       Float
  depositKrw        Float?
  exclusivityDays   Int?
  diligenceDays     Int?
  closeTimelineDays Int?
  submittedAt       DateTime?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deal              Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  counterparty      Counterparty? @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)
  negotiationEvents DealNegotiationEvent[]

  @@index([dealId, submittedAt, createdAt])
  @@index([dealId, status, updatedAt])
  @@index([counterpartyId, createdAt])
}

model DealLenderQuote {
  id               String                @id @default(cuid())
  dealId           String
  counterpartyId   String?
  status           DealLenderQuoteStatus @default(INDICATED)
  facilityLabel    String
  amountKrw        Float
  ltvPct           Float?
  spreadBps        Float?
  allInRatePct     Float?
  dscrFloor        Float?
  termMonths       Int?
  ioMonths         Int?
  quotedAt         DateTime?
  notes            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  deal             Deal                  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  counterparty     Counterparty?         @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)

  @@index([dealId, quotedAt, createdAt])
  @@index([dealId, status, updatedAt])
  @@index([counterpartyId, createdAt])
}

model DealNegotiationEvent {
  id             String                   @id @default(cuid())
  dealId         String
  counterpartyId String?
  bidRevisionId  String?
  eventType      DealNegotiationEventType
  title          String
  effectiveAt    DateTime
  expiresAt      DateTime?
  summary        String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  deal           Deal                     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  counterparty   Counterparty?            @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)
  bidRevision    DealBidRevision?         @relation(fields: [bidRevisionId], references: [id], onDelete: SetNull)

  @@index([dealId, effectiveAt, createdAt])
  @@index([dealId, eventType, updatedAt])
  @@index([counterpartyId, createdAt])
  @@index([bidRevisionId, createdAt])
}

model Task {
  id           String       @id @default(cuid())
  dealId        String
  title        String
  description  String?
  status       TaskStatus   @default(OPEN)
  priority     TaskPriority @default(MEDIUM)
  ownerLabel   String?
  checklistKey String?
  isRequired   Boolean      @default(false)
  dueDate      DateTime?
  completedAt  DateTime?
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deal         Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, status, dueDate])
  @@index([dealId, priority, createdAt])
}

model RiskFlag {
  id          String       @id @default(cuid())
  dealId       String
  title       String
  detail      String?
  severity    RiskSeverity @default(MEDIUM)
  statusLabel String       @default("OPEN")
  isResolved  Boolean      @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deal        Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, isResolved, severity])
}

model ActivityLog {
  id             String       @id @default(cuid())
  dealId          String
  counterpartyId  String?
  activityType   ActivityType @default(GENERAL)
  title          String
  body           String?
  stageFrom      DealStage?
  stageTo        DealStage?
  metadata       Json?
  createdByLabel String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deal           Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  counterparty   Counterparty? @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)

  @@index([dealId, createdAt])
  @@index([counterpartyId, createdAt])
}

model FinancialStatement {
  id                 String             @id @default(cuid())
  assetId            String
  counterpartyId     String
  documentVersionId  String?
  statementType      String
  fiscalYear         Int?
  fiscalPeriod       String?
  periodEndDate      DateTime?
  currency           String             @default("KRW")
  revenueKrw         Float?
  ebitdaKrw          Float?
  cashKrw            Float?
  totalDebtKrw       Float?
  totalAssetsKrw     Float?
  totalEquityKrw     Float?
  interestExpenseKrw Float?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  asset              Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  counterparty       Counterparty       @relation(fields: [counterpartyId], references: [id], onDelete: Cascade)
  documentVersion    DocumentVersion?   @relation(fields: [documentVersionId], references: [id], onDelete: SetNull)
  lineItems          FinancialLineItem[]
  creditAssessments  CreditAssessment[]

  @@index([assetId, counterpartyId, createdAt])
  @@index([documentVersionId, createdAt])
}

model FinancialLineItem {
  id                   String             @id @default(cuid())
  financialStatementId String
  lineKey              String
  lineLabel            String
  valueKrw             Float
  createdAt            DateTime           @default(now())
  financialStatement   FinancialStatement @relation(fields: [financialStatementId], references: [id], onDelete: Cascade)

  @@unique([financialStatementId, lineKey])
  @@index([financialStatementId, lineKey])
}

model CreditAssessment {
  id                   String              @id @default(cuid())
  assetId              String
  counterpartyId       String
  financialStatementId String?
  documentVersionId    String?
  assessmentType       String              @default("COUNTERPARTY_CREDIT")
  score                Float
  riskLevel            String
  summary              String
  metrics              Json
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  asset                Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  counterparty         Counterparty        @relation(fields: [counterpartyId], references: [id], onDelete: Cascade)
  financialStatement   FinancialStatement? @relation(fields: [financialStatementId], references: [id], onDelete: SetNull)
  documentVersion      DocumentVersion?    @relation(fields: [documentVersionId], references: [id], onDelete: SetNull)

  @@index([assetId, createdAt])
  @@index([counterpartyId, createdAt])
  @@index([documentVersionId, createdAt])
}

model Parcel {
  id                   String       @id @default(cuid())
  assetId              String
  parcelId             String
  landUseType          String?
  zoningCode           String?
  landAreaSqm          Float?
  officialLandValueKrw Float?
  roadAccess           String?
  sourceSystem         String
  sourceStatus         SourceStatus @default(MANUAL)
  sourceUpdatedAt      DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  asset                Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, parcelId])
}

model BuildingRecord {
  id                   String       @id @default(cuid())
  assetId              String
  buildingIdentifier   String?
  buildingName         String?
  useType              String?
  approvalDate         DateTime?
  completionDate       DateTime?
  floorCount           Int?
  basementCount        Int?
  grossFloorAreaSqm    Float?
  rentableAreaSqm      Float?
  structureType        String?
  occupancyCertificate String?
  sourceSystem         String
  sourceStatus         SourceStatus @default(MANUAL)
  sourceUpdatedAt      DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  asset                Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, completionDate])
}

model PlanningConstraint {
  id                   String       @id @default(cuid())
  assetId              String
  constraintType       String
  title                String
  description          String?
  severity             String?
  effectiveFrom        DateTime?
  effectiveTo          DateTime?
  sourceLink           String?
  reviewStatus         ReviewStatus @default(PENDING)
  reviewedAt           DateTime?
  reviewedById         String?
  reviewNotes          String?
  sourceSystem         String
  sourceStatus         SourceStatus @default(MANUAL)
  sourceUpdatedAt      DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  asset                Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  reviewedBy           User?        @relation("PlanningConstraintReviewedBy", fields: [reviewedById], references: [id])

  @@index([assetId, constraintType])
}

model OwnershipRecord {
  id                   String       @id @default(cuid())
  assetId              String
  ownerName            String
  entityType           String?
  ownershipPct         Float?
  effectiveDate        DateTime?
  endDate              DateTime?
  sourceLink           String?
  reviewStatus         ReviewStatus @default(PENDING)
  reviewedAt           DateTime?
  reviewedById         String?
  reviewNotes          String?
  sourceSystem         String
  sourceStatus         SourceStatus @default(MANUAL)
  sourceUpdatedAt      DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  asset                Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  reviewedBy           User?        @relation("OwnershipRecordReviewedBy", fields: [reviewedById], references: [id])

  @@index([assetId, effectiveDate])
}

model EncumbranceRecord {
  id                   String       @id @default(cuid())
  assetId              String
  encumbranceType      String
  holderName           String?
  securedAmountKrw     Float?
  priorityRank         Int?
  effectiveDate        DateTime?
  releaseDate          DateTime?
  statusLabel          String?
  sourceLink           String?
