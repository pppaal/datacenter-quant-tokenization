{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["icn1"],
  "installCommand": "npm install && npx prisma generate",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "functions": {
    "app/api/**/route.ts": {
      "maxDuration": 60
    }
  }
}
