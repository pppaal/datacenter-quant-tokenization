# Ignore node_modules in any form — directory OR a stray symlink named
# node_modules (the trailing-slash form only matches directories, so a symlink
# slipped past it once and got committed).
node_modules
node_modules/
.next/
.turbo/
dist/
build/
coverage/
apps/web/storage/
.env
.env.*
!.env.example
*.log
*.tsbuildinfo
.DS_Store
Thumbs.db
apps/web/.runtime/
apps/web/.tmp-valuations.json
apps/web/playwright-report/
apps/web/test-results/

# Local tool state (Claude Code session, auto-memory, editor config)
# Track the shared SessionStart hook + project settings; ignore local state.
.claude/*
!.claude/settings.json
!.claude/hooks/
memory/
.vscode/
